        {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" class="mobile-menu__social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22.54 6.42C22.4 5.89 22.12 5.41 21.73 5.03C21.34 4.65 20.86 4.38 20.33 4.25C18.53 3.79 12 3.79 12 3.79C12 3.79 5.47 3.79 3.67 4.25C3.14 4.38 2.66 4.65 2.27 5.03C1.88 5.41 1.6 5.89 1.46 6.42C1 8.21 1 12 1 12C1 12 1 15.79 1.46 17.58C1.6 18.11 1.88 18.59 2.27 18.97C2.66 19.35 3.14 19.62 3.67 19.75C5.47 20.21 12 20.21 12 20.21C12 20.21 18.53 20.21 20.33 19.75C20.86 19.62 21.34 19.35 21.73 18.97C22.12 18.59 22.4 18.11 22.54 17.58C23 15.79 23 12 23 12C23 12 23 8.21 22.54 6.42Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9.75 15.02L15.5 12L9.75 8.98Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
        {%- if settings.social_twitter != blank -%}<a href="{{ settings.social_twitter }}" class="mobile-menu__social-link" aria-label="X / Twitter" target="_blank" rel="noopener noreferrer"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 4L20 20M20 4L4 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
      </div>
    {%- endif -%}
    <p style="font-size:.72rem;color:var(--color-text-muted);">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
  </div>
</nav>
<div class="menu-overlay" data-menu-overlay aria-hidden="true"></div>

<main id="main-content" role="main" tabindex="-1">{{ content_for_layout }}</main>

<footer class="site-footer" role="contentinfo">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="{{ routes.root_url }}" class="footer__brand-logo" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          {{- settings.logo | image_url: width: 280 | image_tag: loading: 'lazy', widths: '140, 280', sizes: '{{ settings.logo_width | at_most: 160 }}px', alt: shop.name -}}
        {%- else -%}
          <span class="footer__brand-name">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if settings.footer_tagline != blank -%}<p class="footer__tagline">{{ settings.footer_tagline | escape }}</p>{%- endif -%}
      {%- if has_social -%}
        <div class="footer__social" aria-label="Social media links">
          {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1.25" fill="currentColor"/></svg></a>{%- endif -%}
          {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 2H15C13.67 2 12 3.67 12 5V8H9V12H12V22H16V12H19L20 8H16V5C16 4.45 16.45 4 17 4H20V2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
          {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19.59 6.69C18.29 6.62 17.08 6.09 16.19 5.24C15.3 4.4 14.79 3.25 14.77 2H11V15.67C11 16.37 10.73 17.04 10.24 17.54C9.76 18.04 9.1 18.33 8.41 18.35C6.96 18.35 5.75 17.18 5.75 15.72C5.75 14.26 6.96 13.09 8.41 13.09C8.67 13.09 8.92 13.13 9.15 13.2V9.44C8.9 9.41 8.66 9.39 8.41 9.39C4.9 9.39 2.03 12.28 2.03 15.72C2.03 19.16 4.9 22 8.41 22C11.92 22 14.76 19.13 14.76 15.72V9.05C16.09 10.01 17.71 10.57 19.44 10.57V7.04Z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></a>{%- endif -%}
          {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22.54 6.42C22.4 5.89 22.12 5.41 21.73 5.03C21.34 4.65 20.86 4.38 20.33 4.25C18.53 3.79 12 3.79 12 3.79C12 3.79 5.47 3.79 3.67 4.25C3.14 4.38 2.66 4.65 2.27 5.03C1.88 5.41 1.6 5.89 1.46 6.42C1 8.21 1 12 1 12C1 12 1 15.79 1.46 17.58C1.6 18.11 1.88 18.59 2.27 18.97C2.66 19.35 3.14 19.62 3.67 19.75C5.47 20.21 12 20.21 12 20.21C12 20.21 18.53 20.21 20.33 19.75C20.86 19.62 21.34 19.35 21.73 18.97C22.12 18.59 22.4 18.11 22.54 17.58C23 15.79 23 12 23 12C23 12 23 8.21 22.54 6.42Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9.75 15.02L15.5 12L9.75 8.98Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
          {%- if settings.social_twitter != blank -%}<a href="{{ settings.social_twitter }}" class="footer__social-link" aria-label="X / Twitter" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 4L20 20M20 4L4 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
    {%- assign footer_menus = 'footer_menu_1,footer_menu_2,footer_menu_3' | split: ',' -%}
    {%- assign footer_titles = 'footer_menu_1_title,footer_menu_2_title,footer_menu_3_title' | split: ',' -%}
    {%- for menu_key in footer_menus -%}
      {%- assign title_key = footer_titles[forloop.index0] -%}
      {%- assign menu_handle = settings[menu_key] -%}
      {%- if menu_handle != blank and linklists[menu_handle].links.size > 0 -%}
        <nav class="footer__nav" aria-label="{{ settings[title_key] | escape }}">
          {%- if settings[title_key] != blank -%}<p class="footer__nav-title">{{ settings[title_key] | escape }}</p>{%- endif -%}
          <ul class="footer__nav-list" role="list">
            {%- for link in linklists[menu_handle].links -%}
              <li><a href="{{ link.url }}" class="footer__nav-link">{{- link.title | escape -}}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    {%- endfor -%}
    {%- if settings.footer_show_newsletter -%}
      <div class="footer__newsletter">
        <div class="footer__newsletter-text">
          {%- if settings.footer_newsletter_heading != blank -%}<p class="footer__newsletter-heading">{{ settings.footer_newsletter_heading | escape }}</p>{%- endif -%}
          {%- if settings.footer_newsletter_sub != blank -%}<p class="footer__newsletter-sub">{{ settings.footer_newsletter_sub | escape }}</p>{%- endif -%}
        </div>
        {%- form 'customer', class: 'footer__newsletter-form', id: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p style="font-size:.82rem;color:var(--color-accent-light);padding:.75em 0;">Thank you for subscribing!</p>
          {%- else -%}
            <label for="footer-email" class="visually-hidden">Email address</label>
            <input id="footer-email" type="email" name="contact[email]" class="footer__newsletter-input" placeholder="Your email address" autocomplete="email" required aria-required="true">
            <button type="submit" name="commit" class="footer__newsletter-btn">Subscribe</button>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p class="footer__legal">
        {%- if settings.footer_legal != blank -%}
          {{ settings.footer_legal | replace: '{{ year }}', 'now' | date: '%Y' }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}. All rights reserved.
        {%- endif -%}
      </p>
      {%- unless shop.enabled_payment_types == empty -%}
        <div class="footer__payment" aria-label="Accepted payment methods">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_img_url: '160x100' | image_tag: class: 'footer__payment-icon', alt: type | capitalize }}
          {%- endfor -%}
        </div>
      {%- endunless -%}
    </div>
  </div>
</footer>

<script>
(function(){
  document.documentElement.classList.replace('no-js','js');
  var hamburger=document.querySelector('[data-hamburger]');
  var mobileMenu=document.querySelector('[data-mobile-menu]');
  var menuClose=document.querySelector('[data-menu-close]');
  var menuOverlay=document.querySelector('[data-menu-overlay]');
  function openMenu(){mobileMenu.classList.add('is-open');mobileMenu.setAttribute('aria-hidden','false');menuOverlay.style.display='block';requestAnimationFrame(function(){menuOverlay.classList.add('is-visible');});hamburger.setAttribute('aria-expanded','true');document.body.classList.add('menu-open');}
  function closeMenu(){mobileMenu.classList.remove('is-open');mobileMenu.setAttribute('aria-hidden','true');menuOverlay.classList.remove('is-visible');setTimeout(function(){menuOverlay.style.display='';},360);hamburger.setAttribute('aria-expanded','false');document.body.classList.remove('menu-open');}
  if(hamburger)hamburger.addEventListener('click',openMenu);
  if(menuClose)menuClose.addEventListener('click',closeMenu);
  if(menuOverlay)menuOverlay.addEventListener('click',closeMenu);
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&mobileMenu&&mobileMenu.classList.contains('is-open')){closeMenu();if(hamburger)hamburger.focus();}});
  document.querySelectorAll('[data-sub-toggle]').forEach(function(btn){btn.addEventListener('click',function(){var sub=btn.closest('div').nextElementSibling;if(!sub)return;var isOpen=sub.classList.toggle('is-open');btn.classList.toggle('is-open',isOpen);btn.setAttribute('aria-expanded',isOpen?'true':'false');});});
  var header=document.querySelector('[data-header]');
  var isTransparent=header&&header.dataset.transparent==='true';
  if(isTransparent&&header){
    var main=document.getElementById('main-content');
    var firstChild=main&&main.querySelector('.shopify-section:first-child > *');
    if(firstChild&&(firstChild.classList.contains('hero')||firstChild.classList.contains('ib'))){
      header.classList.add('is-transparent');
      var scrollIO=new IntersectionObserver(function(entries){var belowHero=!entries[0].isIntersecting;header.classList.toggle('is-transparent',!belowHero);header.classList.toggle('is-scrolled',belowHero);},{threshold:0.05});
      scrollIO.observe(firstChild);
    }
  }
  if(header&&!isTransparent){
    var sentinel=document.createElement('div');
    sentinel.style.cssText='position:absolute;top:1px;left:0;width:1px;height:1px;pointer-events:none;';
    document.body.insertBefore(sentinel,document.body.firstChild);
    new IntersectionObserver(function(entries){header.classList.toggle('is-scrolled',!entries[0].isIntersecting);}).observe(sentinel);
  }
  window.__hearthUpdateCartCount=function(count){document.querySelectorAll('[data-cart-count]').forEach(function(el){el.textContent=count;el.style.display=count>0?'':'none';});};
})();
</script>
</body>
</html>
