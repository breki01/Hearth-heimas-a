{%- comment -%}
  sections/hero.liquid — Hearth Theme
  Full-width hero with video/image background, text overlay, CTA.
{%- endcomment -%}

{%- liquid
  assign has_video    = false
  assign has_bg_image = false
  if section.settings.video != blank
    assign has_video = true
  elsif section.settings.video_url != blank
    assign has_video = true
  endif
  if section.settings.image != blank
    assign has_bg_image = true
  endif
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  case section.settings.content_position
    when 'top'
      assign vertical_class = 'hero__content--top'
    when 'bottom'
      assign vertical_class = 'hero__content--bottom'
    else
      assign vertical_class = 'hero__content--middle'
  endcase
  case section.settings.content_alignment
    when 'left'
      assign align_class = 'hero__content--left'
    when 'right'
      assign align_class = 'hero__content--right'
    else
      assign align_class = 'hero__content--center'
  endcase
-%}

<section
  id="hero-{{ section.id }}"
  class="hero"
  style="--hero-min-height: {{ section.settings.min_height }}px; --hero-overlay: {{ overlay_opacity }};"
  aria-label="{{ section.settings.heading | strip_html | escape }}"
>
  <div class="hero__media" aria-hidden="true">
    {%- if has_video -%}
      {%- if section.settings.video != blank -%}
        {{- section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'hero__video', preload: 'metadata' -}}
      {%- elsif section.settings.video_url != blank -%}
        {%- assign video_url = section.settings.video_url -%}
        {%- if video_url.type == 'youtube' -%}
          <iframe class="hero__video hero__video--embed"
            src="https://www.youtube.com/embed/{{ video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ video_url.id }}&controls=0&showinfo=0&rel=0&playsinline=1"
            allow="autoplay; encrypted-media" allowfullscreen loading="lazy"
            title="{{ section.settings.heading | strip_html | escape }}"></iframe>
        {%- elsif video_url.type == 'vimeo' -%}
          <iframe class="hero__video hero__video--embed"
            src="https://player.vimeo.com/video/{{ video_url.id }}?autoplay=1&muted=1&loop=1&background=1"
            allow="autoplay; fullscreen" allowfullscreen loading="lazy"
            title="{{ section.settings.heading | strip_html | escape }}"></iframe>
        {%- endif -%}
      {%- endif -%}
      {%- if has_bg_image -%}
        <div class="hero__image-fallback">
          {{- section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 2400', class: 'hero__image' -}}
        </div>
      {%- endif -%}
    {%- elsif has_bg_image -%}
      {{- section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 2400', class: 'hero__image' -}}
    {%- else -%}
      <div class="hero__placeholder"></div>
    {%- endif -%}
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__inner">
    <div class="hero__content {{ vertical_class }} {{ align_class }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero__eyebrow animate-in">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading animate-in animate-in--delay-1">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="hero__subheading animate-in animate-in--delay-2">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="hero__cta animate-in animate-in--delay-3">
          <a href="{{ section.settings.button_link | default: '#' }}"
            class="btn btn--hero {% if section.settings.button_style == 'secondary' %}btn--ghost{% endif %}"
            {% if section.settings.button_link == blank %}aria-disabled="true"{% endif %}>
            <span>{{ section.settings.button_label | escape }}</span>
            <svg class="btn__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_scroll_indicator -%}
    <div class="hero__scroll-indicator animate-in animate-in--delay-4" aria-hidden="true">
      <div class="hero__scroll-line"></div>
      <span class="hero__scroll-label">{{ section.settings.scroll_label | default: 'Scroll' }}</span>
    </div>
  {%- endif -%}
</section>

<style>
  #hero-{{ section.id }} {
    --hero-text-color: {{ section.settings.text_color }};
    --hero-btn-bg: {{ section.settings.button_color }};
    --hero-btn-text: {{ section.settings.button_text_color }};
    --transition-base: 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero { position: relative; width: 100%; min-height: var(--hero-min-height, 100vh); display: flex; align-items: stretch; overflow: hidden; isolation: isolate; }
  .hero__media { position: absolute; inset: 0; z-index: 0; }
  .hero__image, .hero__image-fallback { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero__image-fallback { position: absolute; inset: 0; z-index: 0; }
  .hero__image-fallback img { width: 100%; height: 100%; object-fit: cover; }
  .hero__video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; }
  .hero__video--embed { border: 0; pointer-events: none; width: 100vw; height: 56.25vw; min-height: 100%; min-width: 177.78vh; top: 50%; left: 50%; transform: translate(-50%, -50%); }
  .hero__placeholder { position: absolute; inset: 0; background: linear-gradient(160deg, #1a1008 0%, #2c1a0e 50%, #0d0906 100%); }
  .hero__overlay { position: absolute; inset: 0; z-index: 2; background: rgba(0,0,0,var(--hero-overlay,0.45)); background-image: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.6) 100%), linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,calc(var(--hero-overlay,0.45) * 1.4)) 100%); }
  .hero__inner { position: relative; z-index: 3; width: 100%; display: flex; align-items: stretch; }
  .hero__content { display: flex; flex-direction: column; width: 100%; padding: clamp(4rem,10vw,8rem) clamp(1.5rem,6vw,6rem); gap: clamp(1rem,2.5vw,1.75rem); color: var(--hero-text-color,#ffffff); }
  .hero__content--top { justify-content: flex-start; padding-top: clamp(5rem,12vw,10rem); }
  .hero__content--middle { justify-content: center; }
  .hero__content--bottom { justify-content: flex-end; padding-bottom: clamp(5rem,12vw,10rem); }
  .hero__content--left { align-items: flex-start; text-align: left; max-width: 65ch; }
  .hero__content--center { align-items: center; text-align: center; max-width: 100%; }
  .hero__content--right { align-items: flex-end; text-align: right; margin-left: auto; max-width: 65ch; }
  .hero__eyebrow { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(0.75rem,1.2vw,0.9rem); font-weight: 400; letter-spacing: 0.25em; text-transform: uppercase; opacity: 0.8; margin: 0; }
  .hero__heading { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(2.8rem,7vw,6.5rem); font-weight: 300; line-height: 1.05; letter-spacing: -0.02em; margin: 0; text-shadow: 0 2px 40px rgba(0,0,0,0.3); }
  .hero__subheading { font-family: inherit; font-size: clamp(0.95rem,1.5vw,1.15rem); font-weight: 300; letter-spacing: 0.04em; line-height: 1.7; opacity: 0.85; max-width: 48ch; margin: 0; }
  .hero__content--center .hero__subheading { max-width: 56ch; }
  .hero__cta { margin-top: clamp(0.5rem,2vw,1rem); }
  .btn--hero { display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.9em 2em; background-color: var(--hero-btn-bg,#ffffff); color: var(--hero-btn-text,#1a1008); font-family: inherit; font-size: clamp(0.8rem,1.1vw,0.9rem); font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; border: 1.5px solid transparent; cursor: pointer; transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, gap 0.3s ease, transform 0.3s ease; }
  .btn--hero:hover, .btn--hero:focus-visible { background-color: transparent; color: #ffffff; border-color: rgba(255,255,255,0.7); gap: 0.9rem; outline: none; }
  .btn--ghost { background-color: transparent !important; color: #ffffff !important; border-color: rgba(255,255,255,0.6) !important; }
  .btn--ghost:hover, .btn--ghost:focus-visible { background-color: rgba(255,255,255,0.12) !important; border-color: rgba(255,255,255,0.9) !important; }
  .btn__arrow { flex-shrink: 0; transition: transform 0.3s ease; }
  .btn--hero:hover .btn__arrow { transform: translateX(3px); }
  .hero__scroll-indicator { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); z-index: 4; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.6); font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; }
  .hero__scroll-line { width: 1px; height: 3rem; background: linear-gradient(to bottom, rgba(255,255,255,0.6), transparent); animation: hero-scroll-pulse 2s ease-in-out infinite; }
  @keyframes hero-scroll-pulse { 0%,100%{opacity:.6;transform:scaleY(1)} 50%{opacity:1;transform:scaleY(0.7) translateY(30%)} }
  @media (prefers-reduced-motion: no-preference) {
    .animate-in { opacity: 0; transform: translateY(22px); animation: hero-fade-up var(--transition-base) forwards; }
    .animate-in--delay-1 { animation-delay: 0.15s; }
    .animate-in--delay-2 { animation-delay: 0.3s; }
    .animate-in--delay-3 { animation-delay: 0.45s; }
    .animate-in--delay-4 { animation-delay: 0.8s; }
    @keyframes hero-fade-up { to { opacity: 1; transform: translateY(0); } }
  }
  @media screen and (max-width: 749px) {
    .hero__content--right { align-items: flex-start; text-align: left; margin-left: 0; }
    .hero__video--embed { width: 100%; height: 100%; min-height: 100%; min-width: 100%; top: 0; left: 0; transform: none; }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap"></noscript>

{% schema %}
{
  "name": "Hero — Image / Video",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "video", "id": "video", "label": "Background video (Shopify-hosted)" },
    { "type": "video_url", "id": "video_url", "label": "Background video (YouTube / Vimeo URL)", "accept": ["youtube","vimeo"] },
    { "type": "header", "content": "Overlay" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 45 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Where warmth<br>begins.</p>" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Handcrafted hearths and fireplaces, built to last a lifetime." },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{ "value": "primary", "label": "Solid" },{ "value": "secondary", "label": "Ghost" }], "default": "primary" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "min_height", "label": "Minimum section height", "min": 400, "max": 1000, "step": 50, "unit": "px", "default": 700 },
    { "type": "select", "id": "content_position", "label": "Vertical content position", "options": [{ "value": "top", "label": "Top" },{ "value": "middle", "label": "Middle" },{ "value": "bottom", "label": "Bottom" }], "default": "middle" },
    { "type": "select", "id": "content_alignment", "label": "Horizontal content alignment", "options": [{ "value": "left", "label": "Left" },{ "value": "center", "label": "Center" },{ "value": "right", "label": "Right" }], "default": "left" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#FFFFFF" },
    { "type": "color", "id": "button_color", "label": "Button background", "default": "#FFFFFF" },
    { "type": "color", "id": "button_text_color", "label": "Button text colour", "default": "#1A1008" },
    { "type": "header", "content": "Scroll indicator" },
    { "type": "checkbox", "id": "show_scroll_indicator", "label": "Show scroll indicator", "default": true },
    { "type": "text", "id": "scroll_label", "label": "Scroll indicator label", "default": "Scroll" }
  ],
  "presets": [
    {
      "name": "Hero — Image / Video",
      "settings": {
        "heading": "<p>Where warmth<br>begins.</p>",
        "subheading": "Handcrafted hearths and fireplaces, built to last a lifetime.",
        "button_label": "Explore the collection",
        "overlay_opacity": 45,
        "min_height": 700,
        "content_position": "middle",
        "content_alignment": "left",
        "show_scroll_indicator": true
      }
    }
  ]
}
{% endschema %}
