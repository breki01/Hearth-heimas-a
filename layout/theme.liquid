{%- liquid
  assign heading_scale = 1
  case settings.type_heading_scale
    when 'small'
      assign heading_scale = 0.85
    when 'large'
      assign heading_scale = 1.18
  endcase
  assign nav_letter_spacing = settings.type_nav_spacing | divided_by: 100.0
-%}
<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="theme-color" content="{{ settings.color_bg_primary }}">
{%- if settings.favicon != blank -%}
<link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
{%- endif -%}
{%- unless page_description == blank -%}<meta name="description" content="{{ page_description | escape }}">{%- endunless -%}
{%- if canonical_url != blank -%}<link rel="canonical" href="{{ canonical_url }}">{%- endif -%}
<title>{%- if page_title == shop.name -%}{{ shop.name }}{%- else -%}{{ page_title | escape }} — {{ shop.name }}{%- endif -%}</title>
{{ content_for_header }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap"></noscript>
<style>
:root {
  --color-accent: {{ settings.color_accent }};
  --color-accent-light: {{ settings.color_accent_light }};
  --color-bg: {{ settings.color_bg_primary }};
  --color-bg-2: {{ settings.color_bg_secondary }};
  --color-bg-dark: {{ settings.color_bg_dark }};
  --color-text: {{ settings.color_text }};
  --color-text-muted: {{ settings.color_text_muted }};
  --color-border: {{ settings.color_border }};
  --color-btn-bg: {{ settings.color_button_bg }};
  --color-btn-text: {{ settings.color_button_text }};
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --type-base-size: {{ settings.type_base_size }}px;
  --type-heading-scale: {{ heading_scale }};
  --type-nav-spacing: {{ nav_letter_spacing }}em;
  --page-width: {{ settings.layout_page_width }}px;
  --section-spacing: {{ settings.layout_section_spacing }}px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:var(--type-base-size);-webkit-text-size-adjust:100%;scroll-behavior:smooth}
body{font-family:var(--font-display);font-size:1rem;font-weight:300;line-height:1.65;color:var(--color-text);background-color:var(--color-bg);-webkit-font-smoothing:antialiased;overflow-x:hidden}
body.menu-open{overflow:hidden}
img,svg,video{display:block;max-width:100%}
a{color:inherit}
button{font-family:inherit}
ul[role="list"],ol[role="list"]{list-style:none}
.skip-to-content{position:absolute;top:-100%;left:1rem;z-index:9999;background:var(--color-bg);color:var(--color-text);padding:.75em 1.5em;font-size:.85rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;border:2px solid var(--color-accent);transition:top .2s ease}
.skip-to-content:focus{top:1rem}
#main-content{min-height:50vh;outline:none}
#main-content .shopify-section + .shopify-section{margin-top:var(--section-spacing)}
.visually-hidden{position:absolute!important;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
.js-only{display:none}
.no-js .no-js-hidden{display:none}
</style>
</head>
<body>
<a class="skip-to-content" href="#main-content">{{ 'general.accessibility.skip_to_text' | t }}</a>

{% sections 'header-group' %}

<main id="main-content" role="main" tabindex="-1">{{ content_for_layout }}</main>

{% sections 'footer-group' %}

<script>
(function () {
  document.documentElement.classList.replace('no-js', 'js');
  window.__hearthUpdateCartCount = function (count) {
    document.querySelectorAll('[data-cart-count]').forEach(function (el) {
      el.textContent = count;
      el.style.display = count > 0 ? '' : 'none';
    });
  };
})();
</script>
</body>
</html>
