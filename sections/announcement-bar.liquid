{%- liquid
  assign visible_blocks = 0
  for block in section.blocks
    if block.settings.text != blank
      assign visible_blocks = visible_blocks | plus: 1
    endif
  endfor
-%}

{%- if section.settings.show_bar and visible_blocks > 0 -%}
  <div
    class="announce-bar"
    data-section-id="{{ section.id }}"
    style="--ab-bg: {{ section.settings.bg_color }}; --ab-text: {{ section.settings.text_color }};"
    role="region"
    aria-label="{{ 'sections.header.announcements_aria' | t }}"
  >
    {%- for block in section.blocks -%}
      {%- if block.settings.text != blank -%}
        {%- assign block_bg = block.settings.bg_color_override | default: section.settings.bg_color -%}
        {%- assign block_text = block.settings.text_color_override | default: section.settings.text_color -%}
        <div
          class="announce-bar__item"
          style="background-color: {{ block_bg }}; color: {{ block_text }};"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.link != blank -%}
            <a class="announce-bar__link" href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {%- else -%}
            <span>{{ block.settings.text | escape }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <style>
    .announce-bar { background-color: var(--ab-bg); color: var(--ab-text); position: relative; z-index: 50; }
    .announce-bar__item { text-align: center; padding: 0.55rem 1.25rem; font-size: 0.75rem; font-weight: 400; letter-spacing: 0.1em; }
    .announce-bar__link { color: inherit; text-decoration: underline; text-underline-offset: 3px; }
    .announce-bar__item + .announce-bar__item { border-top: 1px solid rgba(255,255,255,0.12); }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "shopify-section--announcement-bar",
  "enabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show announcement bar", "default": true },
    { "type": "header", "content": "Default colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#1C1410" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#FAF8F5" }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        { "type": "text", "id": "text", "label": "Announcement text", "default": "Free nationwide installation on all orders." },
        { "type": "url", "id": "link", "label": "Optional link" },
        { "type": "header", "content": "Per-announcement colour overrides" },
        { "type": "color", "id": "bg_color_override", "label": "Background override" },
        { "type": "color", "id": "text_color_override", "label": "Text override" }
      ]
    }
  ],
  "max_blocks": 5
}
{% endschema %}
