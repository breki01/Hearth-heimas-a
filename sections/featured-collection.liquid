{%- comment -%}sections/featured-collection.liquid — Hearth Theme{%- endcomment -%}
{%- liquid
  assign collection = section.settings.collection
  assign product_limit = section.settings.product_limit
  assign columns = section.settings.columns_desktop
  assign scheme = section.settings.color_scheme
  if collection != blank
    assign products = collection.products | limit: product_limit
  endif
-%}
<section id="featured-collection-{{ section.id }}" class="fc fc--{{ scheme }}" aria-labelledby="fc-heading-{{ section.id }}" style="--fc-pt:{{ section.settings.padding_top }}px;--fc-pb:{{ section.settings.padding_bottom }}px;--fc-cols:{{ columns }};">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.view_all_label != blank -%}
    <div class="fc__header">
      <div class="fc__header-text">
        {%- if section.settings.eyebrow != blank -%}<p class="fc__eyebrow fc__reveal" style="--rd:0s;">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 id="fc-heading-{{ section.id }}" class="fc__heading fc__reveal" style="--rd:0.1s;">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="fc__subheading fc__reveal" style="--rd:0.2s;">{{ section.settings.subheading | escape }}</p>{%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank and collection != blank -%}
        <div class="fc__header-cta fc__reveal" style="--rd:0.2s;">
          <a href="{{ collection.url }}" class="fc__link-all"><span>{{ section.settings.view_all_label | escape }}</span><svg width="32" height="10" viewBox="0 0 32 10" fill="none" aria-hidden="true"><path d="M0 5H30M30 5L26 1M30 5L26 9" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg></a>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
  <div class="fc__grid" role="list">
    {%- if collection != blank and collection.products_count > 0 -%}
      {%- for product in products -%}
        {%- liquid
          assign card_delay = forloop.index0 | times: 0.07
          assign card_delay_str = card_delay | append: 's'
          assign first_variant = product.selected_or_first_available_variant
          assign compare_price = first_variant.compare_at_price
          assign current_price = first_variant.price
          assign on_sale = false
          if compare_price > current_price
            assign on_sale = true
          endif
        -%}
        <article class="fc__card fc__reveal" style="--rd:{{ card_delay_str }};" role="listitem" aria-label="{{ product.title | escape }}">
          <a href="{{ product.url }}" class="fc__card-media" tabindex="-1" aria-hidden="true">
            <div class="fc__card-img-wrap">
              {%- if product.featured_media -%}
                {{- product.featured_media | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(max-width:599px) 90vw,(max-width:899px) 44vw,30vw', widths: '400,550,700,900', class: 'fc__card-img fc__card-img--primary', alt: product.featured_media.alt | default: product.title | escape -}}
                {%- if product.media[1] != blank and section.settings.hover_image -%}
                  {{- product.media[1] | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(max-width:599px) 90vw,(max-width:899px) 44vw,30vw', widths: '400,550,700,900', class: 'fc__card-img fc__card-img--secondary', alt: product.media[1].alt | default: product.title | escape -}}
                {%- endif -%}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'fc__card-img fc__card-img--placeholder' }}
              {%- endif -%}
            </div>
            <div class="fc__badges" aria-hidden="true">
              {%- if product.available == false -%}<span class="fc__badge fc__badge--sold">Sold out</span>
              {%- elsif on_sale -%}
                {%- assign saving_pct = compare_price | minus: current_price | times: 100 | divided_by: compare_price -%}
                <span class="fc__badge fc__badge--sale">-{{ saving_pct }}%</span>
              {%- endif -%}
            </div>
            {%- if section.settings.show_quick_view -%}<div class="fc__quick-view-hint" aria-hidden="true"><span>Quick view</span></div>{%- endif -%}
          </a>
          <div class="fc__card-info">
            {%- if section.settings.show_vendor and product.vendor != blank -%}<p class="fc__card-vendor">{{ product.vendor | escape }}</p>{%- endif -%}
            <h3 class="fc__card-title"><a href="{{ product.url }}" class="fc__card-title-link">{{ product.title | escape }}</a></h3>
            <div class="fc__card-price">
              {%- if on_sale -%}
                <span class="fc__price fc__price--sale">{{ current_price | money }}</span>
                <s class="fc__price fc__price--compare">{{ compare_price | money }}</s>
              {%- else -%}
                <span class="fc__price">{% if product.price_varies %}<span class="fc__price-from">From </span>{% endif %}{{ product.price_min | money }}</span>
              {%- endif -%}
            </div>
            {%- if section.settings.show_add_to_cart -%}
              {%- if first_variant.available -%}
                <form method="post" action="/cart/add" class="fc__atc-form">
                  <input type="hidden" name="id" value="{{ first_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" name="add" class="fc__atc-btn" aria-label="Add {{ product.title | escape }} to cart">Add to cart</button>
                </form>
              {%- else -%}
                <button class="fc__atc-btn fc__atc-btn--disabled" disabled>Sold out</button>
              {%- endif -%}
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..product_limit) -%}
        {%- assign delay = forloop.index0 | times: 0.07 | append: 's' -%}
        <article class="fc__card fc__card--placeholder fc__reveal" style="--rd:{{ delay }};" role="listitem">
          <div class="fc__card-media"><div class="fc__card-img-wrap">{{ 'product-1' | placeholder_svg_tag: 'fc__card-img fc__card-img--placeholder' }}</div></div>
          <div class="fc__card-info"><div class="fc__placeholder-line fc__placeholder-line--short"></div><div class="fc__placeholder-line"></div><div class="fc__placeholder-line fc__placeholder-line--price"></div></div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
  {%- if section.settings.view_all_label != blank and collection != blank -%}
    <div class="fc__mobile-cta"><a href="{{ collection.url }}" class="fc__mobile-link">{{ section.settings.view_all_label | escape }}<svg width="24" height="10" viewBox="0 0 24 10" fill="none" aria-hidden="true"><path d="M0 5H22M22 5L18 1M22 5L18 9" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg></a></div>
  {%- endif -%}
</section>
<style>
  #featured-collection-{{ section.id }} { --fc-bg:{% if scheme == 'dark' %}#17110C{% else %}#FAF8F5{% endif %};--fc-text:{% if scheme == 'dark' %}#F5EFE8{% else %}#1C1410{% endif %};--fc-text-muted:{% if scheme == 'dark' %}#A8947E{% else %}#6B5B4E{% endif %};--fc-accent:{% if scheme == 'dark' %}#C9A87A{% else %}#8C6A48{% endif %};--fc-border:{% if scheme == 'dark' %}#2C1E14{% else %}#E4DAD0{% endif %};--fc-card-bg:{% if scheme == 'dark' %}#1F1610{% else %}#FFFFFF{% endif %};--fc-card-shadow:{% if scheme == 'dark' %}0 2px 24px rgba(0,0,0,0.35){% else %}0 2px 24px rgba(28,20,16,0.07){% endif %};--fc-price-sale:{% if scheme == 'dark' %}#E07A5A{% else %}#B84A2E{% endif %};--fc-atc-bg:{% if scheme == 'dark' %}#F5EFE8{% else %}#1C1410{% endif %};--fc-atc-text:{% if scheme == 'dark' %}#1C1410{% else %}#FAF8F5{% endif %}; }
  .fc { background-color:var(--fc-bg);color:var(--fc-text);padding:var(--fc-pt,5rem) clamp(1.25rem,5vw,5rem) var(--fc-pb,5rem); }
  .fc__header { display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;margin-bottom:clamp(2.5rem,5vw,4rem); }
  .fc__header-text { display:flex;flex-direction:column;gap:0.6rem; }
  .fc__eyebrow { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(0.7rem,1vw,0.8rem);font-weight:400;letter-spacing:0.25em;text-transform:uppercase;color:var(--fc-accent);margin:0; }
  .fc__heading { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2rem,4vw,3.25rem);font-weight:300;line-height:1.1;letter-spacing:-0.015em;margin:0; }
  .fc__heading em { font-style:italic; }
  .fc__subheading { font-size:clamp(0.85rem,1.2vw,0.95rem);font-weight:300;color:var(--fc-text-muted);margin:0;max-width:52ch; }
  .fc__header-cta { flex-shrink:0;padding-bottom:0.25rem; }
  .fc__link-all { display:inline-flex;align-items:center;gap:0.9rem;font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(0.8rem,1.1vw,0.9rem);font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--fc-text);text-decoration:none;border-bottom:1px solid var(--fc-border);padding-bottom:0.25em;transition:gap 0.35s cubic-bezier(0.22,1,0.36,1),border-color 0.3s ease,color 0.3s ease; }
  .fc__link-all:hover,.fc__link-all:focus-visible { gap:1.5rem;border-color:var(--fc-accent);color:var(--fc-accent);outline:none; }
  .fc__grid { display:grid;grid-template-columns:repeat(var(--fc-cols,3),1fr);gap:clamp(1.25rem,3vw,2rem); }
  .fc__card { display:flex;flex-direction:column;background-color:var(--fc-card-bg);box-shadow:var(--fc-card-shadow);overflow:hidden;position:relative;transition:box-shadow 0.4s ease,transform 0.4s cubic-bezier(0.22,1,0.36,1); }
  .fc__card:hover { box-shadow:0 8px 48px rgba(28,20,16,0.14);transform:translateY(-4px); }
  .fc__card-media { display:block;position:relative;overflow:hidden;aspect-ratio:{{ section.settings.image_ratio }};text-decoration:none;background-color:var(--fc-border); }
  .fc__card-img-wrap { position:absolute;inset:0; }
  .fc__card-img { display:block;width:100%;height:100%;object-fit:cover;transition:transform 0.65s cubic-bezier(0.25,1,0.5,1),opacity 0.45s ease; }
  .fc__card-img--primary { position:relative;z-index:1; }
  .fc__card-img--secondary { position:absolute;inset:0;z-index:2;opacity:0; }
  .fc__card-media:hover .fc__card-img--primary { transform:scale(1.04); }
  .fc__card-media:hover .fc__card-img--secondary { opacity:1; }
  .fc__card-img--placeholder { opacity:0.35;background:var(--fc-border); }
  .fc__badges { position:absolute;top:0.85rem;left:0.85rem;z-index:3;display:flex;flex-direction:column;gap:0.35rem; }
  .fc__badge { display:inline-block;padding:0.2em 0.55em;font-size:0.65rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;line-height:1.4; }
  .fc__badge--sale { background:var(--fc-price-sale);color:#fff; }
  .fc__badge--sold { background:var(--fc-text-muted);color:#fff; }
  .fc__quick-view-hint { position:absolute;bottom:0;left:0;right:0;z-index:4;background:rgba(250,248,245,0.92);color:var(--fc-text);font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;text-align:center;padding:0.7em;transform:translateY(100%);transition:transform 0.35s cubic-bezier(0.22,1,0.36,1);backdrop-filter:blur(4px); }
  .fc__card-media:hover .fc__quick-view-hint { transform:translateY(0); }
  .fc__card-info { display:flex;flex-direction:column;gap:0.45rem;padding:clamp(0.9rem,2vw,1.25rem) clamp(0.9rem,2vw,1.25rem) clamp(1rem,2vw,1.5rem);flex:1; }
  .fc__card-vendor { font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--fc-accent);margin:0; }
  .fc__card-title { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(1rem,1.5vw,1.2rem);font-weight:400;line-height:1.3;margin:0; }
  .fc__card-title-link { color:inherit;text-decoration:none;background-image:linear-gradient(var(--fc-accent),var(--fc-accent));background-repeat:no-repeat;background-position:0 100%;background-size:0 1px;transition:background-size 0.3s ease; }
  .fc__card-title-link:hover { background-size:100% 1px; }
  .fc__card-price { display:flex;align-items:baseline;gap:0.5rem;margin-top:auto;padding-top:0.35rem; }
  .fc__price { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(1rem,1.4vw,1.15rem);font-weight:400;color:var(--fc-text); }
  .fc__price--sale { color:var(--fc-price-sale); }
  .fc__price--compare { font-size:0.85em;color:var(--fc-text-muted);text-decoration:line-through; }
  .fc__price-from { font-size:0.75em;color:var(--fc-text-muted);font-style:italic; }
  .fc__atc-form { margin-top:0.4rem; }
  .fc__atc-btn { width:100%;padding:0.75em 1em;background-color:var(--fc-atc-bg);color:var(--fc-atc-text);font-family:inherit;font-size:0.75rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;border:none;cursor:pointer;transition:opacity 0.25s ease; }
  .fc__atc-btn:hover { opacity:0.82; }
  .fc__atc-btn--disabled { opacity:0.38;cursor:not-allowed;background-color:var(--fc-border);color:var(--fc-text-muted); }
  .fc__placeholder-line { height:0.7rem;border-radius:2px;background:linear-gradient(90deg,var(--fc-border) 25%,rgba(228,218,208,0.4) 50%,var(--fc-border) 75%);background-size:200% 100%;animation:fc-shimmer 1.6s infinite; }
  .fc__placeholder-line--short { width:45%; }
  .fc__placeholder-line--price { width:30%;margin-top:0.4rem; }
  @keyframes fc-shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
  .fc__mobile-cta { display:none;margin-top:clamp(2rem,5vw,3rem);text-align:center; }
  .fc__mobile-link { display:inline-flex;align-items:center;gap:0.75rem;font-family:'Cormorant Garamond',Georgia,serif;font-size:0.85rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--fc-text);text-decoration:none;border-bottom:1px solid var(--fc-border);padding-bottom:0.25em; }
  @media (prefers-reduced-motion:no-preference) {
    .fc__reveal { opacity:0;transform:translateY(24px);transition:opacity 0.7s cubic-bezier(0.22,1,0.36,1) var(--rd,0s),transform 0.7s cubic-bezier(0.22,1,0.36,1) var(--rd,0s); }
    .fc__reveal.is-visible { opacity:1;transform:translateY(0); }
  }
  @media screen and (max-width:1099px) { .fc__grid { --fc-cols:{{ section.settings.columns_desktop | minus: 1 | at_least: 2 }}; } }
  @media screen and (max-width:749px) { .fc__grid { --fc-cols:{{ section.settings.columns_mobile }}; } .fc__header { flex-direction:column;align-items:flex-start; } .fc__header-cta { display:none; } .fc__mobile-cta { display:block; } }
</style>
<script>
(function(){
  var s=document.getElementById('featured-collection-{{ section.id }}');
  if(!s)return;
  var t=s.querySelectorAll('.fc__reveal');
  if(!t.length)return;
  if(!('IntersectionObserver' in window)){t.forEach(function(e){e.classList.add('is-visible');});return;}
  var io=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  t.forEach(function(e){io.observe(e);});
})();
</script>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    { "type": "header", "content": "Collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 6 },
    { "type": "header", "content": "Section heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The collection" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Handpicked for<br><em>your home</em></p>" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View all" },
    { "type": "header", "content": "Card options" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [{ "value": "1/1", "label": "Square" },{ "value": "4/5", "label": "Portrait (4:5)" },{ "value": "3/4", "label": "Tall portrait" },{ "value": "16/9", "label": "Landscape" }], "default": "4/5" },
    { "type": "checkbox", "id": "hover_image", "label": "Show second image on hover", "default": true },
    { "type": "checkbox", "id": "show_quick_view", "label": "Show quick view hint", "default": true },
    { "type": "checkbox", "id": "show_vendor", "label": "Show product vendor", "default": false },
    { "type": "checkbox", "id": "show_rating", "label": "Show star rating", "default": false },
    { "type": "checkbox", "id": "show_add_to_cart", "label": "Show Add to Cart button", "default": true },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 3 },
    { "type": "select", "id": "columns_mobile", "label": "Columns (mobile)", "options": [{ "value": "1", "label": "1 column" },{ "value": "2", "label": "2 columns" }], "default": "2" },
    { "type": "header", "content": "Style" },
    { "type": "select", "id": "color_scheme", "label": "Colour scheme", "options": [{ "value": "light", "label": "Light" },{ "value": "dark", "label": "Dark" }], "default": "light" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": { "eyebrow": "The collection", "heading": "<p>Handpicked for<br><em>your home</em></p>", "view_all_label": "View all", "product_limit": 6, "columns_desktop": 3, "columns_mobile": "2", "image_ratio": "4/5", "hover_image": true, "show_quick_view": true, "show_vendor": false, "show_rating": false, "show_add_to_cart": true, "color_scheme": "light", "padding_top": 80, "padding_bottom": 80 }
    }
  ]
}
{% endschema %}
