{%- liquid
  assign footer_logo_sizes = section.settings.footer_logo_width | append: 'px'

  assign has_social = false
  if settings.social_instagram != blank
    assign has_social = true
  endif
  if settings.social_facebook != blank
    assign has_social = true
  endif
  if settings.social_tiktok != blank
    assign has_social = true
  endif
  if settings.social_youtube != blank
    assign has_social = true
  endif
  if settings.social_twitter != blank
    assign has_social = true
  endif

  assign menu_block_count = 0
  for block in section.blocks
    if block.type == 'menu'
      assign menu_block_count = menu_block_count | plus: 1
    endif
  endfor
-%}

<footer
  class="site-footer"
  role="contentinfo"
  data-section-id="{{ section.id }}"
  style="--footer-bg: {{ section.settings.footer_bg }}; --footer-text: {{ section.settings.footer_text }}; --footer-text-muted: {{ section.settings.footer_text_muted }}; --footer-border: {{ section.settings.footer_border }}; --footer-logo-w: {{ section.settings.footer_logo_width }}px;"
>
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="{{ routes.root_url }}" class="footer__brand-logo" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          {{- settings.logo | image_url: width: 320 | image_tag: loading: 'lazy', widths: '160, 240, 320', sizes: footer_logo_sizes, alt: shop.name -}}
        {%- else -%}
          <span class="footer__brand-name">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if section.settings.tagline != blank -%}<p class="footer__tagline">{{ section.settings.tagline | escape }}</p>{%- endif -%}
      {%- if has_social -%}
        <div class="footer__social" aria-label="{{ 'general.social.links_label' | t }}">
          {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1.25" fill="currentColor"/></svg></a>{%- endif -%}
          {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 2H15C13.67 2 12 3.67 12 5V8H9V12H12V22H16V12H19L20 8H16V5C16 4.45 16.45 4 17 4H20V2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
          {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19.59 6.69C18.29 6.62 17.08 6.09 16.19 5.24C15.3 4.4 14.79 3.25 14.77 2H11V15.67C11 16.37 10.73 17.04 10.24 17.54C9.76 18.04 9.1 18.33 8.41 18.35C6.96 18.35 5.75 17.18 5.75 15.72C5.75 14.26 6.96 13.09 8.41 13.09C8.67 13.09 8.92 13.13 9.15 13.2V9.44C8.9 9.41 8.66 9.39 8.41 9.39C4.9 9.39 2.03 12.28 2.03 15.72C2.03 19.16 4.9 22 8.41 22C11.92 22 14.76 19.13 14.76 15.72V9.05C16.09 10.01 17.71 10.57 19.44 10.57V7.04Z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></a>{%- endif -%}
          {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22.54 6.42C22.4 5.89 22.12 5.41 21.73 5.03C21.34 4.65 20.86 4.38 20.33 4.25C18.53 3.79 12 3.79 12 3.79C12 3.79 5.47 3.79 3.67 4.25C3.14 4.38 2.66 4.65 2.27 5.03C1.88 5.41 1.6 5.89 1.46 6.42C1 8.21 1 12 1 12C1 12 1 15.79 1.46 17.58C1.6 18.11 1.88 18.59 2.27 18.97C2.66 19.35 3.14 19.62 3.67 19.75C5.47 20.21 12 20.21 12 20.21C12 20.21 18.53 20.21 20.33 19.75C20.86 19.62 21.34 19.35 21.73 18.97C22.12 18.59 22.4 18.11 22.54 17.58C23 15.79 23 12 23 12C23 12 23 8.21 22.54 6.42Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9.75 15.02L15.5 12L9.75 8.98Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
          {%- if settings.social_twitter != blank -%}<a href="{{ settings.social_twitter }}" class="footer__social-link" aria-label="X / Twitter" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 4L20 20M20 4L4 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        {%- assign menu_handle = block.settings.menu -%}
        {%- if menu_handle != blank and linklists[menu_handle].links.size > 0 -%}
          {%- assign nav_label = block.settings.heading | default: 'sections.footer.menu_aria' -%}
          {%- if block.settings.heading == blank -%}{%- assign nav_label = 'sections.footer.menu_aria' | t -%}{%- endif -%}
          <nav class="footer__nav" aria-label="{{ nav_label | escape }}" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}<p class="footer__nav-title">{{ block.settings.heading | escape }}</p>{%- endif -%}
            <ul class="footer__nav-list" role="list">
              {%- for link in linklists[menu_handle].links -%}
                <li><a href="{{ link.url }}" class="footer__nav-link">{{- link.title | escape -}}</a></li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if section.settings.show_newsletter -%}
      <div class="footer__newsletter">
        <div class="footer__newsletter-text">
          {%- if section.settings.newsletter_heading != blank -%}<p class="footer__newsletter-heading">{{ section.settings.newsletter_heading | escape }}</p>{%- endif -%}
          {%- if section.settings.newsletter_sub != blank -%}<p class="footer__newsletter-sub">{{ section.settings.newsletter_sub | escape }}</p>{%- endif -%}
        </div>
        {%- form 'customer', class: 'footer__newsletter-form', id: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p style="font-size:.82rem;color:var(--color-accent-light);padding:.75em 0;">{{ 'sections.footer.thank_you_subscribed' | t }}</p>
          {%- else -%}
            <label for="footer-email" class="visually-hidden">{{ 'customer.login.email' | t }}</label>
            <input id="footer-email" type="email" name="contact[email]" class="footer__newsletter-input" placeholder="{{ 'general.newsletter.email_placeholder' | t }}" autocomplete="email" required aria-required="true">
            <button type="submit" name="commit" class="footer__newsletter-btn">{{ 'general.newsletter.button_label' | t }}</button>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p class="footer__legal">
        {%- if section.settings.legal != blank -%}
          {%- assign current_year = 'now' | date: '%Y' -%}
          {{ section.settings.legal | replace: '[year]', current_year }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}. {{ 'sections.footer.all_rights_reserved' | t }}
        {%- endif -%}
      </p>
      {%- unless shop.enabled_payment_types == empty -%}
        <div class="footer__payment" aria-label="{{ 'sections.footer.payment_methods_aria' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_img_url: '160x100' | image_tag: class: 'footer__payment-icon', alt: type | capitalize }}
          {%- endfor -%}
        </div>
      {%- endunless -%}
    </div>
  </div>
</footer>

<style>
  .site-footer { background-color: var(--footer-bg); color: var(--footer-text); }
  .footer__inner { max-width: var(--page-width); margin: 0 auto; padding: clamp(3.5rem,7vw,6rem) clamp(1.25rem,4vw,3.5rem) clamp(2.5rem,5vw,4rem); display: grid; grid-template-columns: 1.4fr repeat(3,1fr); gap: clamp(2rem,4vw,4rem); align-items: start; }
  .footer__brand { display: flex; flex-direction: column; gap: 1rem; }
  .footer__brand-logo { display: block; opacity: .9; }
  .footer__brand-logo img { width: var(--footer-logo-w); max-width: 100%; height: auto; filter: brightness(0) invert(1); opacity: .85; }
  .footer__brand-name { font-family: var(--font-display); font-size: clamp(1.3rem,2.5vw,1.75rem); font-weight: 300; letter-spacing: -.02em; color: var(--footer-text); }
  .footer__tagline { font-size: .82rem; font-weight: 300; line-height: 1.65; color: var(--footer-text-muted); max-width: 28ch; }
  .footer__social { display: flex; gap: .75rem; margin-top: .5rem; }
  .footer__social-link { display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; color: var(--footer-text-muted); border: 1px solid var(--footer-border); text-decoration: none; transition: color .2s ease, border-color .2s ease; }
  .footer__social-link:hover { color: var(--footer-text); border-color: var(--footer-text-muted); }
  .footer__nav { display: flex; flex-direction: column; gap: .9rem; }
  .footer__nav-title { font-size: .68rem; font-weight: 500; letter-spacing: .2em; text-transform: uppercase; color: var(--footer-text); margin-bottom: .25rem; }
  .footer__nav-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .55rem; }
  .footer__nav-link { font-size: .82rem; font-weight: 300; color: var(--footer-text-muted); text-decoration: none; transition: color .2s ease; line-height: 1.4; }
  .footer__nav-link:hover { color: var(--footer-text); }
  .footer__newsletter { grid-column: 1 / -1; border-top: 1px solid var(--footer-border); padding-top: clamp(1.75rem,3vw,2.5rem); display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .footer__newsletter-text { display: flex; flex-direction: column; gap: .35rem; }
  .footer__newsletter-heading { font-family: var(--font-display); font-size: clamp(1.25rem,2.5vw,1.75rem); font-weight: 300; letter-spacing: -.01em; color: var(--footer-text); }
  .footer__newsletter-sub { font-size: .8rem; color: var(--footer-text-muted); font-weight: 300; max-width: 44ch; line-height: 1.6; }
  .footer__newsletter-form { display: flex; gap: 0; flex-shrink: 0; }
  .footer__newsletter-input { width: clamp(220px,30vw,300px); height: 46px; border: 1px solid var(--footer-border); border-right: none; background: transparent; color: var(--footer-text); font-family: inherit; font-size: .82rem; font-weight: 300; padding: 0 1em; transition: border-color .2s ease; }
  .footer__newsletter-input::placeholder { color: var(--footer-text-muted); opacity: .7; }
  .footer__newsletter-input:focus { outline: none; border-color: var(--footer-text-muted); }
  .footer__newsletter-btn { height: 46px; padding: 0 1.5em; background: var(--color-accent-light); color: var(--color-bg-dark); border: none; font-family: inherit; font-size: .72rem; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; cursor: pointer; white-space: nowrap; transition: opacity .2s ease; }
  .footer__newsletter-btn:hover { opacity: .85; }
  .footer__bottom { background: var(--footer-bg); border-top: 1px solid var(--footer-border); }
  .footer__bottom-inner { max-width: var(--page-width); margin: 0 auto; padding: 1.1rem clamp(1.25rem,4vw,3.5rem); display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .footer__legal { font-size: .7rem; color: var(--footer-text-muted); line-height: 1.5; }
  .footer__legal a { color: var(--footer-text-muted); text-decoration: underline; text-underline-offset: 2px; }
  .footer__payment { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }
  .footer__payment-icon { height: 22px; width: auto; opacity: .55; }
  @media screen and (max-width:1099px) { .footer__inner { grid-template-columns: 1fr 1fr; } .footer__brand { grid-column: 1 / -1; } }
  @media screen and (max-width:899px) { .footer__inner { grid-template-columns: 1fr 1fr; } .footer__newsletter { flex-direction: column; align-items: flex-start; } .footer__newsletter-input { width: 100%; } .footer__newsletter-form { width: 100%; } }
  @media screen and (max-width:599px) { .footer__inner { grid-template-columns: 1fr; } .footer__bottom-inner { flex-direction: column; align-items: flex-start; gap: .75rem; } }
</style>

{% schema %}
{
  "name": "Footer",
  "class": "shopify-section--footer",
  "enabled_on": { "groups": ["footer"] },
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "textarea", "id": "tagline", "label": "Footer tagline", "default": "Handcrafted hearths and fireplaces, built to last a lifetime." },
    { "type": "range", "id": "footer_logo_width", "label": "Footer logo width", "min": 80, "max": 240, "step": 4, "unit": "px", "default": 160 },
    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter sign-up", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Stay warm" },
    { "type": "text", "id": "newsletter_sub", "label": "Newsletter subtext", "default": "Inspiration, new arrivals, and exclusive offers." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "footer_bg", "label": "Footer background", "default": "#17110C" },
    { "type": "color", "id": "footer_text", "label": "Footer text", "default": "#F5EFE8" },
    { "type": "color", "id": "footer_text_muted", "label": "Footer muted text", "default": "#A8947E" },
    { "type": "color", "id": "footer_border", "label": "Footer border", "default": "#2C1E14" },
    { "type": "header", "content": "Bottom bar" },
    { "type": "richtext", "id": "legal", "label": "Legal / copyright text", "info": "Use [year] to insert the current year." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "info": "Pick a navigation menu created in Online Store → Navigation." }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
