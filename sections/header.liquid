{%- liquid
  assign header_logo_sizes = section.settings.logo_width | append: 'px'
  assign mobile_logo_width = section.settings.logo_width | at_most: 140
  assign mobile_logo_sizes = mobile_logo_width | append: 'px'

  assign has_social = false
  if settings.social_instagram != blank
    assign has_social = true
  endif
  if settings.social_facebook != blank
    assign has_social = true
  endif
  if settings.social_tiktok != blank
    assign has_social = true
  endif
  if settings.social_youtube != blank
    assign has_social = true
  endif
  if settings.social_twitter != blank
    assign has_social = true
  endif
-%}

<header
  class="site-header{% if section.settings.header_sticky %} site-header--sticky{% endif %}"
  role="banner"
  data-header
  data-section-id="{{ section.id }}"
  data-transparent="{{ section.settings.header_transparent }}"
  style="--header-bg: {{ section.settings.header_bg }}; --header-text: {{ section.settings.header_text }}; --header-text-transparent: {{ section.settings.header_text_transparent }}; --header-height: {{ section.settings.header_height }}px; --header-logo-w: {{ section.settings.logo_width }}px;"
>
  <div class="header__inner">
    <button class="header__hamburger" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu-{{ section.id }}" data-hamburger>
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
    </button>
    <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        {{- settings.logo | image_url: width: 560 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '140, 200, 280, 420, 560', sizes: header_logo_sizes, class: 'header__logo-img', alt: shop.name -}}
      {%- else -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list" role="list">
        {%- for link in linklists[section.settings.header_menu].links -%}
          <li class="header__nav-item">
            {%- if link.links.size > 0 -%}
              <a href="{{ link.url }}" class="header__nav-link{% if link.active %} is-active{% endif %}" aria-haspopup="true">
                {{- link.title | escape -}}
                <svg class="header__nav-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              </a>
              <ul class="header__dropdown" role="list">
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}" class="header__dropdown-link{% if child.active %} is-active{% endif %}">{{- child.title | escape -}}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <a href="{{ link.url }}" class="header__nav-link{% if link.active %} is-active{% endif %}">{{- link.title | escape -}}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
    <div class="header__icons" role="list">
      <a href="{{ routes.search_url }}" class="header__icon-btn" aria-label="Search" role="listitem"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.4"/><path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></a>
      <a href="{{ routes.cart_url }}" class="header__icon-btn" aria-label="Cart — {{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %}" role="listitem" data-cart-link>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3 3H5L7 13H14L16 6H5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8" cy="15.5" r="1.25" fill="currentColor"/><circle cx="13" cy="15.5" r="1.25" fill="currentColor"/></svg>
        <span class="header__cart-count" data-cart-count{% if cart.item_count == 0 %} style="display:none"{% endif %} aria-hidden="true">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<nav id="mobile-menu-{{ section.id }}" class="mobile-menu" aria-label="Mobile navigation" aria-hidden="true" data-mobile-menu>
  <div class="mobile-menu__header">
    <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        {{- settings.logo | image_url: width: 280 | image_tag: loading: 'lazy', widths: '140, 280', sizes: mobile_logo_sizes, class: 'header__logo-img', alt: shop.name -}}
      {%- else -%}
        <span class="header__logo-text" style="font-size:1.1rem;">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <button type="button" class="mobile-menu__close" aria-label="Close navigation menu" data-menu-close>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3 3L15 15M15 3L3 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
  </div>
  <div class="mobile-menu__nav">
    {%- for link in linklists[section.settings.header_menu].links -%}
      {%- if link.links.size > 0 -%}
        <div>
          <div style="display:flex;align-items:center;border-bottom:1px solid var(--color-border);">
            <a href="{{ link.url }}" class="mobile-menu__link{% if link.active %} is-active{% endif %}" style="flex:1;border-bottom:none;">{{- link.title | escape -}}</a>
            <button type="button" class="mobile-menu__sub-toggle" aria-label="Toggle {{ link.title | escape }} submenu" aria-expanded="false" data-sub-toggle style="padding:.9rem 1.25rem;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
            </button>
          </div>
          <ul class="mobile-menu__sub" role="list">
            {%- for child in link.links -%}
              <li><a href="{{ child.url }}" class="mobile-menu__sub-link{% if child.active %} is-active{% endif %}">{{- child.title | escape -}}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- else -%}
        <a href="{{ link.url }}" class="mobile-menu__link{% if link.active %} is-active{% endif %}">{{- link.title | escape -}}</a>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="mobile-menu__footer">
    {%- if has_social -%}
      <div class="mobile-menu__footer-icons" aria-label="Social links">
        {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" class="mobile-menu__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1.25" fill="currentColor"/></svg></a>{%- endif -%}
        {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" class="mobile-menu__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M18 2H15C13.67 2 12 3.67 12 5V8H9V12H12V22H16V12H19L20 8H16V5C16 4.45 16.45 4 17 4H20V2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
        {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" class="mobile-menu__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M19.59 6.69C18.29 6.62 17.08 6.09 16.19 5.24C15.3 4.4 14.79 3.25 14.77 2H11V15.67C11 16.37 10.73 17.04 10.24 17.54C9.76 18.04 9.1 18.33 8.41 18.35C6.96 18.35 5.75 17.18 5.75 15.72C5.75 14.26 6.96 13.09 8.41 13.09C8.67 13.09 8.92 13.13 9.15 13.2V9.44C8.9 9.41 8.66 9.39 8.41 9.39C4.9 9.39 2.03 12.28 2.03 15.72C2.03 19.16 4.9 22 8.41 22C11.92 22 14.76 19.13 14.76 15.72V9.05C16.09 10.01 17.71 10.57 19.44 10.57V7.04C19.49 7.06 19.54 7.06 19.59 7.06Z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></a>{%- endif -%}
        {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" class="mobile-menu__social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22.54 6.42C22.4 5.89 22.12 5.41 21.73 5.03C21.34 4.65 20.86 4.38 20.33 4.25C18.53 3.79 12 3.79 12 3.79C12 3.79 5.47 3.79 3.67 4.25C3.14 4.38 2.66 4.65 2.27 5.03C1.88 5.41 1.6 5.89 1.46 6.42C1 8.21 1 12 1 12C1 12 1 15.79 1.46 17.58C1.6 18.11 1.88 18.59 2.27 18.97C2.66 19.35 3.14 19.62 3.67 19.75C5.47 20.21 12 20.21 12 20.21C12 20.21 18.53 20.21 20.33 19.75C20.86 19.62 21.34 19.35 21.73 18.97C22.12 18.59 22.4 18.11 22.54 17.58C23 15.79 23 12 23 12C23 12 23 8.21 22.54 6.42Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9.75 15.02L15.5 12L9.75 8.98Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
        {%- if settings.social_twitter != blank -%}<a href="{{ settings.social_twitter }}" class="mobile-menu__social-link" aria-label="X / Twitter" target="_blank" rel="noopener noreferrer"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 4L20 20M20 4L4 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>{%- endif -%}
      </div>
    {%- endif -%}
    <p style="font-size:.72rem;color:var(--color-text-muted);">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
  </div>
</nav>
<div class="menu-overlay" data-menu-overlay aria-hidden="true"></div>

<style>
  .site-header { position: relative; top: 0; z-index: 40; background-color: var(--header-bg); border-bottom: 1px solid var(--color-border); transition: background-color .35s ease, border-color .35s ease, box-shadow .35s ease; }
  .site-header--sticky { position: sticky; }
  .site-header.is-transparent { background-color: transparent; border-bottom-color: transparent; --header-text: var(--header-text-transparent); }
  .site-header.is-scrolled { box-shadow: 0 2px 24px rgba(0,0,0,.08); background-color: var(--header-bg); border-bottom-color: var(--color-border); }
  .header__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 clamp(1.25rem,4vw,3.5rem); height: var(--header-height); display: flex; align-items: center; gap: 2rem; color: var(--header-text); }
  .header__logo-link { display: flex; align-items: center; flex-shrink: 0; text-decoration: none; color: var(--header-text); transition: opacity .2s ease; }
  .header__logo-link:hover { opacity: .75; }
  .header__logo-img { width: var(--header-logo-w); height: auto; max-height: calc(var(--header-height) - 24px); object-fit: contain; }
  .header__logo-text { font-family: var(--font-display); font-size: clamp(1.2rem,2.5vw,1.75rem); font-weight: 300; letter-spacing: -.02em; white-space: nowrap; }
  .header__nav { display: flex; align-items: center; flex: 1; justify-content: center; }
  .header__nav-list { display: flex; align-items: center; gap: .25rem; list-style: none; padding: 0; margin: 0; }
  .header__nav-item { position: relative; }
  .header__nav-link { display: flex; align-items: center; gap: .3rem; padding: .45em .85em; font-size: .78rem; font-weight: 400; letter-spacing: var(--type-nav-spacing); text-transform: uppercase; color: var(--header-text); text-decoration: none; transition: color .2s ease; white-space: nowrap; }
  .header__nav-link:hover, .header__nav-link.is-active { color: var(--color-accent); }
  .header__nav-chevron { flex-shrink: 0; color: var(--header-text); opacity: .5; transition: transform .25s ease; }
  .header__nav-item:hover .header__nav-chevron { transform: rotate(180deg); }
  .header__dropdown { position: absolute; top: calc(100% + .5rem); left: 50%; transform: translateX(-50%) translateY(-6px); min-width: 200px; background: var(--color-bg); border: 1px solid var(--color-border); box-shadow: 0 8px 32px rgba(0,0,0,.1); list-style: none; padding: .5rem 0; margin: 0; opacity: 0; pointer-events: none; transition: opacity .25s cubic-bezier(.22,1,.36,1), transform .25s cubic-bezier(.22,1,.36,1); z-index: 10; }
  .header__nav-item:hover .header__dropdown, .header__nav-item:focus-within .header__dropdown { opacity: 1; pointer-events: all; transform: translateX(-50%) translateY(0); }
  .header__dropdown-link { display: block; padding: .55em 1.25em; font-size: .78rem; letter-spacing: .05em; color: var(--color-text); text-decoration: none; transition: color .2s ease, background-color .2s ease; }
  .header__dropdown-link:hover { color: var(--color-accent); background-color: var(--color-bg-2); }
  .header__icons { display: flex; align-items: center; gap: .25rem; flex-shrink: 0; }
  .header__icon-btn { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; color: var(--header-text); cursor: pointer; text-decoration: none; transition: color .2s ease; position: relative; }
  .header__icon-btn:hover { color: var(--color-accent); }
  .header__icon-btn:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
  .header__cart-count { position: absolute; top: 5px; right: 4px; width: 16px; height: 16px; border-radius: 50%; background: var(--color-accent); color: #fff; font-size: .55rem; font-weight: 700; display: flex; align-items: center; justify-content: center; line-height: 1; pointer-events: none; }
  .header__hamburger { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 40px; height: 40px; background: transparent; border: none; cursor: pointer; padding: .5rem; flex-shrink: 0; }
  .header__hamburger-line { display: block; width: 100%; height: 1.5px; background-color: var(--header-text); transition: transform .35s cubic-bezier(.22,1,.36,1), opacity .25s ease; transform-origin: center; }
  .menu-open .header__hamburger-line:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-open .header__hamburger-line:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .menu-open .header__hamburger-line:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
  .mobile-menu { position: fixed; top: 0; left: 0; width: min(340px,88vw); height: 100%; z-index: 200; background: var(--color-bg); transform: translateX(-100%); transition: transform .4s cubic-bezier(.22,1,.36,1); overflow-y: auto; display: flex; flex-direction: column; scrollbar-width: none; }
  .mobile-menu::-webkit-scrollbar { display: none; }
  .mobile-menu.is-open { transform: translateX(0); }
  .mobile-menu__header { display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 1.5rem; border-bottom: 1px solid var(--color-border); flex-shrink: 0; }
  .mobile-menu__close { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; color: var(--color-text-muted); cursor: pointer; transition: color .2s ease; }
  .mobile-menu__close:hover { color: var(--color-text); }
  .mobile-menu__nav { flex: 1; padding: 1rem 0; overflow-y: auto; }
  .mobile-menu__link { display: flex; align-items: center; justify-content: space-between; padding: .9rem 1.5rem; font-size: clamp(1rem,3vw,1.1rem); font-weight: 300; font-family: var(--font-display); color: var(--color-text); text-decoration: none; border-bottom: 1px solid var(--color-border); transition: color .2s ease, background-color .2s ease; }
  .mobile-menu__link:hover, .mobile-menu__link.is-active { color: var(--color-accent); background-color: var(--color-bg-2); }
  .mobile-menu__sub-toggle { background: none; border: none; color: var(--color-text-muted); cursor: pointer; padding: .25rem; display: flex; align-items: center; transition: transform .3s ease, color .2s ease; }
  .mobile-menu__sub-toggle.is-open { transform: rotate(180deg); }
  .mobile-menu__sub { display: none; flex-direction: column; background: var(--color-bg-2); }
  .mobile-menu__sub.is-open { display: flex; }
  .mobile-menu__sub-link { display: block; padding: .75rem 1.5rem .75rem 2.5rem; font-size: .9rem; color: var(--color-text-muted); text-decoration: none; border-bottom: 1px solid var(--color-border); transition: color .2s ease; }
  .mobile-menu__sub-link:hover { color: var(--color-accent); }
  .mobile-menu__footer { padding: 1.5rem; border-top: 1px solid var(--color-border); display: flex; flex-direction: column; gap: 1rem; flex-shrink: 0; }
  .mobile-menu__footer-icons { display: flex; gap: 1rem; }
  .mobile-menu__social-link { color: var(--color-text-muted); transition: color .2s ease; }
  .mobile-menu__social-link:hover { color: var(--color-accent); }
  .menu-overlay { display: none; position: fixed; inset: 0; z-index: 199; background: rgba(0,0,0,.5); opacity: 0; transition: opacity .35s ease; }
  .menu-overlay.is-visible { opacity: 1; pointer-events: all; }
  @media screen and (max-width:899px) {
    .header__nav { display: none; }
    .header__hamburger { display: flex; }
  }
</style>

<script>
(function () {
  var sectionId = {{ section.id | json }};
  var observers = [];
  var cleanupFns = [];

  function initHeader() {
    var section = document.querySelector('[data-section-id="' + sectionId + '"][data-header]');
    if (!section) return;
    if (section.dataset.headerInitialized === 'true') return;
    section.dataset.headerInitialized = 'true';

    var sectionRoot = document.getElementById('shopify-section-' + sectionId);
    var hamburger = section.querySelector('[data-hamburger]');
    var mobileMenu = sectionRoot && sectionRoot.querySelector('[data-mobile-menu]');
    var menuClose = sectionRoot && sectionRoot.querySelector('[data-menu-close]');
    var menuOverlay = sectionRoot && sectionRoot.querySelector('[data-menu-overlay]');

    function openMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.add('is-open');
      mobileMenu.setAttribute('aria-hidden', 'false');
      if (menuOverlay) {
        menuOverlay.style.display = 'block';
        requestAnimationFrame(function () { menuOverlay.classList.add('is-visible'); });
      }
      if (hamburger) hamburger.setAttribute('aria-expanded', 'true');
      document.body.classList.add('menu-open');
    }
    function closeMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.remove('is-open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      if (menuOverlay) {
        menuOverlay.classList.remove('is-visible');
        setTimeout(function () { menuOverlay.style.display = ''; }, 360);
      }
      if (hamburger) hamburger.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('menu-open');
    }
    function onKeydown(e) {
      if (e.key === 'Escape' && mobileMenu && mobileMenu.classList.contains('is-open')) {
        closeMenu();
        if (hamburger) hamburger.focus();
      }
    }
    function onSubToggle(btn) {
      return function () {
        var sub = btn.closest('div').nextElementSibling;
        if (!sub) return;
        var isOpen = sub.classList.toggle('is-open');
        btn.classList.toggle('is-open', isOpen);
        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      };
    }

    if (hamburger) {
      hamburger.addEventListener('click', openMenu);
      cleanupFns.push(function () { hamburger.removeEventListener('click', openMenu); });
    }
    if (menuClose) {
      menuClose.addEventListener('click', closeMenu);
      cleanupFns.push(function () { menuClose.removeEventListener('click', closeMenu); });
    }
    if (menuOverlay) {
      menuOverlay.addEventListener('click', closeMenu);
      cleanupFns.push(function () { menuOverlay.removeEventListener('click', closeMenu); });
    }
    document.addEventListener('keydown', onKeydown);
    cleanupFns.push(function () { document.removeEventListener('keydown', onKeydown); });

    if (sectionRoot) {
      sectionRoot.querySelectorAll('[data-sub-toggle]').forEach(function (btn) {
        var handler = onSubToggle(btn);
        btn.addEventListener('click', handler);
        cleanupFns.push(function () { btn.removeEventListener('click', handler); });
      });
    }

    var isTransparent = section.dataset.transparent === 'true';
    if (isTransparent) {
      var main = document.getElementById('main-content');
      var firstChild = main && main.querySelector('.shopify-section:first-child > *');
      if (firstChild && (firstChild.classList.contains('hero') || firstChild.classList.contains('ib'))) {
        section.classList.add('is-transparent');
        var heroIO = new IntersectionObserver(function (entries) {
          var belowHero = !entries[0].isIntersecting;
          section.classList.toggle('is-transparent', !belowHero);
          section.classList.toggle('is-scrolled', belowHero);
        }, { threshold: 0.05 });
        heroIO.observe(firstChild);
        observers.push(heroIO);
      }
    } else {
      var sentinel = document.createElement('div');
      sentinel.style.cssText = 'position:absolute;top:1px;left:0;width:1px;height:1px;pointer-events:none;';
      sentinel.dataset.headerSentinel = sectionId;
      document.body.insertBefore(sentinel, document.body.firstChild);
      var scrollIO = new IntersectionObserver(function (entries) {
        section.classList.toggle('is-scrolled', !entries[0].isIntersecting);
      });
      scrollIO.observe(sentinel);
      observers.push(scrollIO);
      cleanupFns.push(function () { if (sentinel.parentNode) sentinel.parentNode.removeChild(sentinel); });
    }
  }

  function teardown() {
    observers.forEach(function (o) { o.disconnect(); });
    observers.length = 0;
    cleanupFns.forEach(function (fn) { try { fn(); } catch (e) {} });
    cleanupFns.length = 0;
    var section = document.querySelector('[data-section-id="' + sectionId + '"][data-header]');
    if (section) section.dataset.headerInitialized = '';
  }

  initHeader();

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail.sectionId === sectionId) initHeader();
  });
  document.addEventListener('shopify:section:unload', function (e) {
    if (e.detail.sectionId === sectionId) teardown();
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "class": "shopify-section--header",
  "enabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 60, "max": 280, "step": 4, "unit": "px", "default": 140 },
    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "header_menu", "label": "Main navigation menu", "default": "main-menu" },
    { "type": "header", "content": "Behaviour" },
    { "type": "checkbox", "id": "header_sticky", "label": "Sticky header", "default": true },
    { "type": "checkbox", "id": "header_transparent", "label": "Transparent over hero", "default": true },
