{%- comment -%}
  sections/marquee-strip.liquid — Hearth Theme
  Infinite auto-scrolling ticker strip. Pure CSS animation.
{%- endcomment -%}

{%- liquid
  assign scheme    = section.settings.color_scheme
  assign speed     = section.settings.scroll_speed
  assign direction = section.settings.scroll_direction
  assign separator = section.settings.separator_style
  assign block_count = section.blocks.size
-%}

{%- if block_count > 0 -%}
<section
  id="marquee-{{ section.id }}"
  class="mq mq--{{ scheme }}"
  aria-label="{{ 'sections.marquee.aria' | t }}"
  style="--mq-pt: {{ section.settings.padding_top }}px; --mq-pb: {{ section.settings.padding_bottom }}px; --mq-speed: {{ speed }}s; --mq-font-size: {{ section.settings.font_size }}px;"
>
  {%- if section.settings.strip_label != blank -%}
    <div class="mq__label" aria-hidden="true">{{ section.settings.strip_label | escape }}</div>
  {%- endif -%}
  <div class="mq__mask" aria-hidden="true"></div>
  <div class="mq__viewport" role="marquee" aria-live="off">
    <div class="mq__track{% if direction == 'right' %} mq__track--rtl{% endif %}" aria-hidden="true">
      {%- for n in (1..2) -%}
        <ul class="mq__list" role="list">
          {%- for block in section.blocks -%}
            <li class="mq__item" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != 'none' -%}
                <span class="mq__icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'flame' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 14C5.79 14 4 12.21 4 10C4 7.5 6 5.5 6 3C7 4 7.5 5.5 7.5 5.5C7.5 5.5 9.5 4 9.5 2C11.5 3.5 12 6 12 8C12 11.31 10.21 14 8 14Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'leaf' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 3C13 3 11 9 8 11C5 13 2 13 2 13C2 13 3 10 5 8C7 6 13 3 13 3Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 13L7 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                    {%- when 'shield' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L3 4V8C3 11 5.5 13.5 8 14C10.5 13.5 13 11 13 8V4L8 2Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.5 8L7 9.5L10.5 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'star' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L9.8 6.2L14 6.6L10.9 9.4L11.8 13.5L8 11.3L4.2 13.5L5.1 9.4L2 6.6L6.2 6.2L8 2Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'truck' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 3H10V11H1V3Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 6H13L15 9V11H10V6Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="3.5" cy="12.5" r="1.5" stroke="currentColor" stroke-width="1.1"/><circle cx="12.5" cy="12.5" r="1.5" stroke="currentColor" stroke-width="1.1"/></svg>
                    {%- when 'checkmark' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M5 8L7 10L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'award' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="6.5" r="4" stroke="currentColor" stroke-width="1.2"/><path d="M5.5 9.5L4.5 14L8 12.5L11.5 14L10.5 9.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'heart' -%}<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 13C8 13 2 9.5 2 5.5C2 3.5 3.5 2 5.5 2C6.7 2 7.7 2.7 8 3.3C8.3 2.7 9.3 2 10.5 2C12.5 2 14 3.5 14 5.5C14 9.5 8 13 8 13Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {%- endcase -%}
                </span>
              {%- endif -%}
              <span class="mq__text">{{ block.settings.text | escape }}</span>
              {%- unless forloop.last and n == 2 -%}
                <span class="mq__sep mq__sep--{{ separator }}" aria-hidden="true">
                  {%- case separator -%}
                    {%- when 'dot' -%}&#8226;
                    {%- when 'diamond' -%}&#9670;
                    {%- when 'slash' -%}/
                    {%- when 'line' -%}<span class="mq__sep-line"></span>
                    {%- when 'flame' -%}<svg width="10" height="12" viewBox="0 0 10 12" fill="none" aria-hidden="true"><path d="M5 11C3.34 11 2 9.66 2 8C2 6 4 4.5 4 3C4.75 3.75 5.12 4.75 5.12 4.75C5.12 4.75 6.75 3.5 6.75 2C8.25 3.12 8.5 5 8.5 6.5C8.5 9 7.24 11 5 11Z" stroke="currentColor" stroke-width="1"/></svg>
                  {%- endcase -%}
                </span>
              {%- endunless -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #marquee-{{ section.id }} { --mq-bg:#F2EDE6;--mq-text:#1C1410;--mq-accent:#8C6A48;--mq-border-top:#E4DAD0;--mq-border-bot:#E4DAD0;--mq-label-bg:#1C1410;--mq-label-text:#FAF8F5; }
  #marquee-{{ section.id }}.mq--dark { --mq-bg:#1C1410;--mq-text:#F5EFE8;--mq-accent:#C9A87A;--mq-border-top:#2C1E14;--mq-border-bot:#2C1E14;--mq-label-bg:#FAF8F5;--mq-label-text:#1C1410; }
  #marquee-{{ section.id }}.mq--accent { --mq-bg:#8C6A48;--mq-text:#FAF8F5;--mq-accent:#FAF8F5;--mq-border-top:transparent;--mq-border-bot:transparent;--mq-label-bg:#FAF8F5;--mq-label-text:#8C6A48; }
  #marquee-{{ section.id }}.mq--charcoal { --mq-bg:#2C1E14;--mq-text:#C9A87A;--mq-accent:#FAF8F5;--mq-border-top:#3D2D20;--mq-border-bot:#3D2D20;--mq-label-bg:#C9A87A;--mq-label-text:#1C1410; }
  .mq { position:relative;background-color:var(--mq-bg);border-top:1px solid var(--mq-border-top);border-bottom:1px solid var(--mq-border-bot);padding-top:var(--mq-pt,0px);padding-bottom:var(--mq-pb,0px);overflow:hidden;display:flex;align-items:center; }
  .mq__label { position:relative;z-index:3;flex-shrink:0;background-color:var(--mq-label-bg);color:var(--mq-label-text);font-size:calc(var(--mq-font-size,13px)*0.85);font-weight:500;letter-spacing:0.18em;text-transform:uppercase;padding:0.85em 1.5em;align-self:stretch;display:flex;align-items:center;white-space:nowrap; }
  .mq__mask { position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(to right,var(--mq-bg) 0%,transparent 6%,transparent 94%,var(--mq-bg) 100%); }
  .mq__label ~ .mq__mask { background:linear-gradient(to right,transparent 0%,transparent 94%,var(--mq-bg) 100%); }
  .mq__viewport { flex:1;min-width:0;overflow:hidden; }
  .mq__track { display:flex;width:max-content;animation:mq-scroll var(--mq-speed,30s) linear infinite;will-change:transform; }
  .mq__track--rtl { animation-name:mq-scroll-rtl; }
  .mq__track:hover, .mq__viewport:focus-within .mq__track { animation-play-state:paused; }
  @keyframes mq-scroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }
  @keyframes mq-scroll-rtl { from{transform:translateX(-50%)} to{transform:translateX(0)} }
  @media (prefers-reduced-motion:reduce) { .mq__track { animation:none;flex-wrap:wrap;width:100%;justify-content:center; } }
  .mq__list { display:flex;align-items:center;list-style:none;margin:0;padding:0;flex-shrink:0; }
  .mq__item { display:flex;align-items:center;gap:0.6em;padding:0.9em 0;white-space:nowrap;color:var(--mq-text);font-size:var(--mq-font-size,13px);font-weight:{{ section.settings.font_weight }};letter-spacing:{{ section.settings.letter_spacing }}em;{% if section.settings.uppercase %}text-transform:uppercase;{% endif %}font-family:'Cormorant Garamond',Georgia,serif; }
  .mq__icon { display:flex;align-items:center;flex-shrink:0;color:var(--mq-accent); }
  .mq__sep { display:flex;align-items:center;flex-shrink:0;color:var(--mq-accent);margin:0 clamp(0.9em,2vw,1.8em);font-size:0.65em;opacity:0.7; }
  .mq__sep--line { margin:0 clamp(1.2em,2.5vw,2.5em); }
  .mq__sep-line { display:block;width:1px;height:1.1em;background-color:var(--mq-accent);opacity:0.5; }
  .mq__sep--flame { font-size:1em;opacity:0.8; }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Marquee Strip",
  "tag": "section",
  "class": "section-marquee",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Strip label" },
    { "type": "text", "id": "strip_label", "label": "Pinned left label" },
    { "type": "header", "content": "Scroll" },
    { "type": "range", "id": "scroll_speed", "label": "Scroll speed", "min": 10, "max": 90, "step": 5, "unit": "s", "default": 35, "info": "Lower = faster." },
    { "type": "select", "id": "scroll_direction", "label": "Scroll direction", "options": [{ "value": "left", "label": "Left" },{ "value": "right", "label": "Right" }], "default": "left" },
    { "type": "header", "content": "Separator" },
    { "type": "select", "id": "separator_style", "label": "Separator", "options": [{ "value": "dot", "label": "Dot" },{ "value": "diamond", "label": "Diamond" },{ "value": "slash", "label": "Slash" },{ "value": "line", "label": "Line" },{ "value": "flame", "label": "Flame" }], "default": "flame" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "font_size", "label": "Font size", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 13 },
    { "type": "select", "id": "font_weight", "label": "Font weight", "options": [{ "value": "300", "label": "Light" },{ "value": "400", "label": "Regular" },{ "value": "500", "label": "Medium" }], "default": "400" },
    { "type": "range", "id": "letter_spacing", "label": "Letter spacing (÷100 em)", "min": 0, "max": 30, "step": 1, "default": 15 },
    { "type": "checkbox", "id": "uppercase", "label": "Uppercase text", "default": true },
    { "type": "header", "content": "Style" },
    { "type": "select", "id": "color_scheme", "label": "Colour scheme", "options": [{ "value": "light", "label": "Light" },{ "value": "dark", "label": "Dark" },{ "value": "accent", "label": "Accent" },{ "value": "charcoal", "label": "Charcoal + gold" }], "default": "light" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 0 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free UK Installation" },
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "none", "label": "None" },{ "value": "flame", "label": "Flame" },{ "value": "leaf", "label": "Leaf" },{ "value": "shield", "label": "Shield" },{ "value": "star", "label": "Star" },{ "value": "truck", "label": "Truck" },{ "value": "checkmark", "label": "Checkmark" },{ "value": "award", "label": "Award" },{ "value": "heart", "label": "Heart" }], "default": "flame" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Strip",
      "settings": { "strip_label": "Why Hearth", "scroll_speed": 35, "scroll_direction": "left", "separator_style": "flame", "font_size": 13, "font_weight": "400", "letter_spacing": 15, "uppercase": true, "color_scheme": "dark", "padding_top": 0, "padding_bottom": 0 },
      "blocks": [
        { "type": "item", "settings": { "text": "Free Nationwide Installation", "icon": "truck" } },
        { "type": "item", "settings": { "text": "10-Year Structural Warranty", "icon": "shield" } },
        { "type": "item", "settings": { "text": "Handcrafted in Britain", "icon": "flame" } },
        { "type": "item", "settings": { "text": "Certified Carbon Neutral", "icon": "leaf" } },
        { "type": "item", "settings": { "text": "5-Star Rated", "icon": "star" } },
        { "type": "item", "settings": { "text": "Bespoke Designs Available", "icon": "award" } }
      ]
    }
  ]
}
{% endschema %}
