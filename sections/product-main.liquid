    { "type": "richtext", "id": "details_content", "label": "Accordion 2 content" },
    { "type": "text", "id": "shipping_label", "label": "Accordion 3 label", "default": "Shipping & Returns" },
    { "type": "richtext", "id": "shipping_content", "label": "Accordion 3 content", "default": "<p>Free delivery on all UK mainland orders. Estimated 5–10 working days after installation survey. Returns accepted within 30 days.</p>" },
    { "type": "text", "id": "care_label", "label": "Accordion 4 label", "default": "Care & Installation" },
    { "type": "richtext", "id": "care_content", "label": "Accordion 4 content" },
    { "type": "header", "content": "Sticky bar" },
    { "type": "checkbox", "id": "show_sticky_bar", "label": "Show sticky add-to-cart bar on scroll", "default": true },
    { "type": "header", "content": "Style" },
    { "type": "select", "id": "color_scheme", "label": "Colour scheme", "options": [{ "value": "light", "label": "Light" },{ "value": "dark", "label": "Dark" }], "default": "light" }
  ]
}
