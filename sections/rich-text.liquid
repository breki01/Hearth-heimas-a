{%- comment -%}sections/rich-text.liquid — Hearth Theme{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme
  assign alignment = section.settings.text_alignment
  assign layout = section.settings.body_layout
  assign has_stats = false
  for i in (1..4)
    assign val_key = 'stat_' | append: i | append: '_value'
    assign label_key = 'stat_' | append: i | append: '_label'
    if section.settings[val_key] != blank and section.settings[label_key] != blank
      assign has_stats = true
      break
    endif
  endfor
  assign has_cta = false
  if section.settings.button_1_label != blank
    assign has_cta = true
  endif
  if section.settings.button_2_label != blank
    assign has_cta = true
  endif
-%}
<section id="rich-text-{{ section.id }}" class="rt rt--{{ scheme }} rt--align-{{ alignment }}" aria-label="{{ section.settings.heading | strip_html | escape }}" style="--rt-pt:{{ section.settings.padding_top }}px;--rt-pb:{{ section.settings.padding_bottom }}px;--rt-max-width:{{ section.settings.content_max_width }}ch;">
  <div class="rt__inner">
    {%- if section.settings.show_top_ornament -%}
      <div class="rt__ornament rt__ornament--top rt__reveal" style="--rd:0s;" aria-hidden="true">
        {%- case section.settings.ornament_style -%}
          {%- when 'line' -%}<span class="rt__orn-line"></span>
          {%- when 'flame' -%}<svg width="18" height="24" viewBox="0 0 18 24" fill="none"><path d="M9 23C5.13 23 2 19.87 2 16C2 11.5 6 8.5 6 5C7.5 7 8.25 9.5 8.25 9.5C8.25 9.5 12.5 7 12.5 3C15.5 5.5 16 10 16 13C16 18.52 12.97 23 9 23Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {%- when 'diamond' -%}<span class="rt__orn-rule"></span><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><rect x="5" y="0.5" width="6.36" height="6.36" rx="0.5" transform="rotate(45 5 0.5)" stroke="currentColor" stroke-width="1"/></svg><span class="rt__orn-rule"></span>
          {%- when 'arch' -%}<svg width="48" height="24" viewBox="0 0 48 24" fill="none"><path d="M1 23 C1 23 1 1 24 1 C47 1 47 23 47 23" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
        {%- endcase -%}
      </div>
    {%- endif -%}
    {%- if section.settings.eyebrow != blank -%}<p class="rt__eyebrow rt__reveal" style="--rd:0.05s;">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="rt__heading rt__reveal" style="--rd:0.12s;--rt-heading-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}<div class="rt__intro rt__reveal" style="--rd:0.2s;">{{ section.settings.intro }}</div>{%- endif -%}
    {%- liquid
      assign has_heading_or_intro = false
      if section.settings.intro != blank or section.settings.heading != blank
        assign has_heading_or_intro = true
      endif
      assign has_body_or_quote = false
      if section.settings.body != blank or section.settings.pull_quote != blank
        assign has_body_or_quote = true
      endif
    -%}
    {%- if section.settings.show_mid_divider and has_heading_or_intro and has_body_or_quote -%}
      <div class="rt__divider rt__reveal" style="--rd:0.25s;" aria-hidden="true"><span class="rt__div-line"></span><span class="rt__div-dot"></span><span class="rt__div-line"></span></div>
    {%- endif -%}
    {%- if section.settings.pull_quote != blank -%}
      <blockquote class="rt__pull-quote rt__reveal" style="--rd:0.28s;">
        <p>{{ section.settings.pull_quote | escape }}</p>
        {%- if section.settings.pull_quote_attr != blank -%}<footer><cite class="rt__pull-attr">&mdash;&nbsp;{{ section.settings.pull_quote_attr | escape }}</cite></footer>{%- endif -%}
      </blockquote>
    {%- endif -%}
    {%- if section.settings.body != blank -%}<div class="rt__body rt__reveal rt__body--{{ layout }}" style="--rd:0.32s;">{{ section.settings.body }}</div>{%- endif -%}
    {%- if has_stats -%}
      <div class="rt__stats rt__reveal" style="--rd:0.38s;" role="list">
        {%- for i in (1..4) -%}
          {%- assign val_key = 'stat_' | append: i | append: '_value' -%}
          {%- assign label_key = 'stat_' | append: i | append: '_label' -%}
          {%- if section.settings[val_key] != blank and section.settings[label_key] != blank -%}
            <div class="rt__stat" role="listitem"><span class="rt__stat-value">{{ section.settings[val_key] | escape }}</span><span class="rt__stat-label">{{ section.settings[label_key] | escape }}</span></div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if has_cta -%}
      <div class="rt__cta rt__reveal" style="--rd:0.44s;">
        {%- if section.settings.button_1_label != blank -%}
          <a href="{{ section.settings.button_1_link | default: '#' }}" class="rt__btn rt__btn--primary" {% if section.settings.button_1_link == blank %}aria-disabled="true"{% endif %}><span>{{ section.settings.button_1_label | escape }}</span><svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank -%}
          <a href="{{ section.settings.button_2_link | default: '#' }}" class="rt__btn rt__btn--ghost" {% if section.settings.button_2_link == blank %}aria-disabled="true"{% endif %}>{{ section.settings.button_2_label | escape }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if section.settings.show_bottom_ornament -%}<div class="rt__ornament rt__ornament--bottom rt__reveal" style="--rd:0.5s;" aria-hidden="true"><span class="rt__orn-line rt__orn-line--short"></span></div>{%- endif -%}
  </div>
</section>
<style>
  #rich-text-{{ section.id }} { --rt-bg:{% if scheme == 'dark' %}#17110C{% elsif scheme == 'warm' %}#F2EDE6{% elsif scheme == 'charcoal' %}#2C1E14{% else %}#FAF8F5{% endif %};--rt-text:{% if scheme == 'dark' %}#F5EFE8{% else %}#1C1410{% endif %};--rt-text-muted:{% if scheme == 'dark' %}#A8947E{% elsif scheme == 'charcoal' %}#C9A87A{% else %}#6B5B4E{% endif %};--rt-accent:{% if scheme == 'dark' or scheme == 'charcoal' %}#C9A87A{% else %}#8C6A48{% endif %};--rt-border:{% if scheme == 'dark' %}#2C1E14{% elsif scheme == 'warm' %}#D4C5B5{% elsif scheme == 'charcoal' %}#3D2D20{% else %}#E4DAD0{% endif %};--rt-pull-bg:{% if scheme == 'dark' %}#1F1610{% elsif scheme == 'warm' %}#FAF8F5{% elsif scheme == 'charcoal' %}#1F1610{% else %}#F2EDE6{% endif %};--rt-stat-value:{% if scheme == 'charcoal' %}#C9A87A{% else %}var(--rt-text){% endif %};--rt-btn-bg:{% if scheme == 'dark' %}#F5EFE8{% elsif scheme == 'charcoal' %}#C9A87A{% else %}#1C1410{% endif %};--rt-btn-text:{% if scheme == 'dark' or scheme == 'charcoal' %}#1C1410{% else %}#FAF8F5{% endif %};--rt-ornament:#C5B5A5; }
  .rt { background-color:var(--rt-bg);color:var(--rt-text);padding-top:var(--rt-pt,5rem);padding-bottom:var(--rt-pb,5rem);padding-left:clamp(1.25rem,6vw,5rem);padding-right:clamp(1.25rem,6vw,5rem); }
  .rt__inner { max-width:var(--rt-max-width,72ch);display:flex;flex-direction:column;gap:clamp(1.5rem,3vw,2.25rem); }
  .rt--align-center .rt__inner { margin-left:auto;margin-right:auto;align-items:center; }
  .rt--align-left .rt__inner { margin-left:0;margin-right:auto;align-items:flex-start; }
  .rt--align-right .rt__inner { margin-left:auto;margin-right:0;align-items:flex-end; }
  .rt__ornament { display:flex;align-items:center;gap:0.75rem;color:var(--rt-ornament); }
  .rt__orn-line { display:block;width:3rem;height:1px;background-color:var(--rt-ornament); }
  .rt__orn-line--short { width:1.5rem; }
  .rt__orn-rule { display:block;flex:1;max-width:3rem;height:1px;background-color:var(--rt-ornament); }
  .rt__eyebrow { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(0.7rem,1vw,0.8rem);font-weight:400;letter-spacing:0.25em;text-transform:uppercase;color:var(--rt-accent);margin:0; }
  .rt__heading { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2rem,4vw,var(--rt-heading-size,48px));font-weight:300;line-height:1.1;letter-spacing:-0.02em;color:var(--rt-text);margin:0; }
  .rt__heading em { font-style:italic;font-weight:300; }
  .rt__intro { width:100%;margin:0; }
  .rt__intro p { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(1.1rem,2vw,1.4rem);font-weight:300;font-style:italic;line-height:1.7;color:var(--rt-text-muted);margin:0 0 0.75em; }
  .rt__divider { display:flex;align-items:center;gap:0.75rem;width:100%;max-width:12rem;color:var(--rt-ornament); }
  .rt--align-center .rt__divider { align-self:center; }
  .rt__div-line { flex:1;height:1px;background-color:var(--rt-border); }
  .rt__div-dot { width:5px;height:5px;border-radius:50%;background-color:var(--rt-accent);flex-shrink:0; }
  .rt__pull-quote { background-color:var(--rt-pull-bg);border-left:3px solid var(--rt-accent);padding:clamp(1.25rem,3vw,2rem);margin:0;width:100%; }
  .rt--align-center .rt__pull-quote { border-left:none;border-top:2px solid var(--rt-accent); }
  .rt__pull-quote p { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(1.15rem,2.2vw,1.5rem);font-weight:300;font-style:italic;line-height:1.6;color:var(--rt-text);margin:0 0 0.6em; }
  .rt__pull-attr { font-size:0.8rem;font-style:normal;letter-spacing:0.08em;color:var(--rt-text-muted); }
  .rt__body { width:100%;margin:0; }
  .rt__body--single p { font-size:clamp(0.9rem,1.4vw,1rem);font-weight:300;line-height:1.85;color:var(--rt-text-muted);margin:0 0 1em; }
  .rt__body--two-col { columns:2;column-gap:clamp(2rem,5vw,4rem);column-rule:1px solid var(--rt-border); }
  .rt__body--two-col p { font-size:clamp(0.85rem,1.2vw,0.95rem);font-weight:300;line-height:1.85;color:var(--rt-text-muted);margin:0 0 0.85em;break-inside:avoid; }
  .rt__stats { display:flex;flex-wrap:wrap;gap:clamp(1.5rem,4vw,3.5rem);width:100%;padding-top:clamp(1rem,2vw,1.5rem);border-top:1px solid var(--rt-border); }
  .rt--align-center .rt__stats { justify-content:center; }
  .rt__stat { display:flex;flex-direction:column;gap:0.3rem; }
  .rt__stat-value { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;line-height:1;letter-spacing:-0.03em;color:var(--rt-stat-value); }
  .rt__stat-label { font-size:0.72rem;font-weight:400;letter-spacing:0.18em;text-transform:uppercase;color:var(--rt-text-muted); }
  .rt__cta { display:flex;flex-wrap:wrap;align-items:center;gap:1rem; }
  .rt__btn { display:inline-flex;align-items:center;gap:0.6rem;text-decoration:none;font-size:clamp(0.75rem,1vw,0.85rem);font-weight:500;letter-spacing:0.12em;text-transform:uppercase;transition:gap 0.3s cubic-bezier(0.22,1,0.36,1),background-color 0.3s ease,color 0.3s ease,border-color 0.3s ease; }
  .rt__btn:focus-visible { outline:2px solid var(--rt-accent);outline-offset:4px; }
  .rt__btn--primary { background-color:var(--rt-btn-bg);color:var(--rt-btn-text);padding:0.85em 1.9em;border:1.5px solid transparent; }
  .rt__btn--primary:hover { background-color:transparent;color:var(--rt-text);border-color:var(--rt-border);gap:0.9rem; }
  .rt__btn--ghost { background-color:transparent;color:var(--rt-text);border:1.5px solid var(--rt-border);padding:0.85em 1.9em;opacity:0.7; }
  .rt__btn--ghost:hover { opacity:1; }
  .rt__btn svg { flex-shrink:0;transition:transform 0.3s ease; }
  .rt__btn--primary:hover svg { transform:translateX(3px); }
  @media (prefers-reduced-motion:no-preference) {
    .rt__reveal { opacity:0;transform:translateY(20px);transition:opacity 0.7s cubic-bezier(0.22,1,0.36,1) var(--rd,0s),transform 0.7s cubic-bezier(0.22,1,0.36,1) var(--rd,0s); }
    .rt__reveal.is-visible { opacity:1;transform:translateY(0); }
  }
  @media screen and (max-width:749px) { .rt__body--two-col { columns:1;column-rule:none; } .rt--align-right .rt__inner { align-items:flex-start; } }
</style>
<script>
(function(){
  var s=document.getElementById('rich-text-{{ section.id }}');
  if(!s)return;
  var t=s.querySelectorAll('.rt__reveal');
  if(!t.length)return;
  if(!('IntersectionObserver' in window)){t.forEach(function(e){e.classList.add('is-visible');});return;}
  var io=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:0.1,rootMargin:'0px 0px -30px 0px'});
  t.forEach(function(e){io.observe(e);});
})();
</script>

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "class": "section-rich-text",
  "settings": [
    { "type": "header", "content": "Ornament" },
    { "type": "checkbox", "id": "show_top_ornament", "label": "Show top ornament", "default": true },
    { "type": "select", "id": "ornament_style", "label": "Ornament style", "options": [{ "value": "line", "label": "Simple line" },{ "value": "flame", "label": "Flame icon" },{ "value": "diamond", "label": "Line + diamond" },{ "value": "arch", "label": "Arch" }], "default": "flame" },
    { "type": "checkbox", "id": "show_bottom_ornament", "label": "Show bottom ornament line", "default": false },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>More than a fireplace.<br><em>A feeling.</em></p>" },
    { "type": "select", "id": "heading_tag", "label": "Heading HTML tag", "options": [{ "value": "h1", "label": "H1" },{ "value": "h2", "label": "H2" },{ "value": "h3", "label": "H3" }], "default": "h2" },
    { "type": "range", "id": "heading_size", "label": "Heading size (desktop)", "min": 28, "max": 96, "step": 2, "unit": "px", "default": 56 },
    { "type": "richtext", "id": "intro", "label": "Intro text", "default": "<p>For over a decade, we have been building hearths that bring families together.</p>" },
    { "type": "checkbox", "id": "show_mid_divider", "label": "Show divider between intro and body", "default": true },
    { "type": "textarea", "id": "pull_quote", "label": "Pull quote" },
    { "type": "text", "id": "pull_quote_attr", "label": "Pull quote attribution" },
    { "type": "richtext", "id": "body", "label": "Body text" },
    { "type": "select", "id": "body_layout", "label": "Body text layout", "options": [{ "value": "single", "label": "Single column" },{ "value": "two-col", "label": "Two columns" }], "default": "single" },
    { "type": "header", "content": "Stats (optional)" },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 — value", "default": "10+" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 — label", "default": "Years of craft" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 — value", "default": "3,000+" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 — label", "default": "Homes warmed" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 — value", "default": "5\u2605" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 — label", "default": "Average rating" },
    { "type": "text", "id": "stat_4_value", "label": "Stat 4 — value" },
    { "type": "text", "id": "stat_4_label", "label": "Stat 4 — label" },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "button_1_label", "label": "Button 1 label", "default": "Our story" },
    { "type": "url", "id": "button_1_link", "label": "Button 1 link" },
    { "type": "text", "id": "button_2_label", "label": "Button 2 label" },
    { "type": "url", "id": "button_2_link", "label": "Button 2 link" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "text_alignment", "label": "Text alignment", "options": [{ "value": "left", "label": "Left" },{ "value": "center", "label": "Center" },{ "value": "right", "label": "Right" }], "default": "center" },
    { "type": "range", "id": "content_max_width", "label": "Content max width", "min": 40, "max": 120, "step": 2, "unit": "ch", "default": 72 },
    { "type": "header", "content": "Style" },
    { "type": "select", "id": "color_scheme", "label": "Colour scheme", "options": [{ "value": "light", "label": "Light" },{ "value": "dark", "label": "Dark" },{ "value": "warm", "label": "Warm" },{ "value": "charcoal", "label": "Charcoal + gold" }], "default": "light" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 }
  ],
  "presets": [
    {
      "name": "Rich Text",
      "settings": { "eyebrow": "Our philosophy", "heading": "<p>More than a fireplace.<br><em>A feeling.</em></p>", "heading_tag": "h2", "heading_size": 56, "intro": "<p>For over a decade, we have been building hearths that bring families together.</p>", "show_mid_divider": true, "body_layout": "single", "stat_1_value": "10+", "stat_1_label": "Years of craft", "stat_2_value": "3,000+", "stat_2_label": "Homes warmed", "stat_3_value": "5\u2605", "stat_3_label": "Average rating", "button_1_label": "Our story", "show_top_ornament": true, "ornament_style": "flame", "text_alignment": "center", "content_max_width": 72, "color_scheme": "light", "padding_top": 100, "padding_bottom": 100 }
    }
  ]
}
{% endschema %}
