{%- comment -%}sections/split-feature.liquid — Hearth Theme{%- endcomment -%}
{%- liquid
  assign img_left = false
  if section.settings.image_position == 'left'
    assign img_left = true
  endif
  assign scheme = section.settings.color_scheme
  assign has_features = false
  for i in (1..3)
    assign key = 'feature_' | append: i
    if section.settings[key] != blank
      assign has_features = true
      break
    endif
  endfor
-%}
<section id="split-{{ section.id }}" class="split{% if img_left %} split--img-left{% else %} split--img-right{% endif %} split--{{ scheme }}" data-section-id="{{ section.id }}" aria-label="{{ section.settings.heading | strip_html | escape }}" style="--split-pt:{{ section.settings.padding_top }}px;--split-pb:{{ section.settings.padding_bottom }}px;--split-img-h:{{ section.settings.image_height }}px;">
  <div class="split__grid">
    <div class="split__media split__reveal split__reveal--media">
      {%- if section.settings.image != blank -%}
        <div class="split__image-wrap">
          {{- section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', sizes: '(max-width:749px) 100vw, 50vw', widths: '375,550,750,900,1100,1400', class: 'split__image' -}}
          {%- if section.settings.image_caption != blank -%}<p class="split__caption">{{ section.settings.image_caption | escape }}</p>{%- endif -%}
        </div>
      {%- else -%}
        <div class="split__image-wrap split__image-wrap--placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'split__placeholder-svg' }}</div>
      {%- endif -%}
    </div>
    <div class="split__body">
      {%- if section.settings.show_rule -%}<div class="split__rule split__reveal" style="--reveal-delay:0s;"></div>{%- endif -%}
      {%- if section.settings.eyebrow != blank -%}<p class="split__eyebrow split__reveal" style="--reveal-delay:0.05s;">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="split__heading split__reveal" style="--reveal-delay:0.15s;">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="split__text split__reveal" style="--reveal-delay:0.25s;">{{ section.settings.text }}</div>{%- endif -%}
      {%- if has_features -%}
        <ul class="split__features split__reveal" style="--reveal-delay:0.35s;" role="list">
          {%- for i in (1..3) -%}
            {%- assign key = 'feature_' | append: i -%}
            {%- if section.settings[key] != blank -%}
              <li class="split__feature-item">
                <svg class="split__feature-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6.25" stroke="currentColor" stroke-width="1"/><path d="M4.5 7L6.5 9L9.5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>{{ section.settings[key] | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="split__cta split__reveal" style="--reveal-delay:0.45s;">
          <a href="{{ section.settings.button_link | default: '#' }}" class="split__btn" {% if section.settings.button_link == blank %}aria-disabled="true"{% endif %}>
            <span>{{ section.settings.button_label | escape }}</span>
            <svg width="38" height="12" viewBox="0 0 38 12" fill="none" aria-hidden="true" class="split__btn-arrow"><path d="M0 6H36M36 6L31 1M36 6L31 11" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
<style>
  #split-{{ section.id }} { --split-bg:{% if scheme == 'dark' %}#17110C{% else %}#FAF8F5{% endif %};--split-text:{% if scheme == 'dark' %}#F5EFE8{% else %}#1C1410{% endif %};--split-text-muted:{% if scheme == 'dark' %}#A8947E{% else %}#6B5B4E{% endif %};--split-accent:{% if scheme == 'dark' %}#C9A87A{% else %}#8C6A48{% endif %};--split-rule-color:{% if scheme == 'dark' %}#3D2D20{% else %}#D4C5B5{% endif %}; }
  .split { background-color:var(--split-bg);color:var(--split-text);padding-top:var(--split-pt,5rem);padding-bottom:var(--split-pb,5rem);overflow:hidden; }
  .split__grid { display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr;min-height:var(--split-img-h,560px); }
  .split--img-right .split__media { order:2; }
  .split--img-right .split__body { order:1; }
  .split__media { position:relative;overflow:hidden; }
  .split__image-wrap { position:absolute;inset:0; }
  .split__image { display:block;width:100%;height:100%;object-fit:cover;object-position:center;transition:transform 0.8s cubic-bezier(0.25,1,0.5,1); }
  .split__media:hover .split__image { transform:scale(1.03); }
  .split__image-wrap--placeholder { background:var(--split-rule-color); }
  .split__placeholder-svg { width:100%;height:100%;object-fit:cover;opacity:0.4; }
  .split__caption { position:absolute;bottom:1.25rem;left:50%;transform:translateX(-50%);white-space:nowrap;font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.7);background:rgba(0,0,0,0.35);padding:0.3em 0.8em;backdrop-filter:blur(4px); }
  .split__body { display:flex;flex-direction:column;justify-content:center;padding:clamp(3rem,7vw,6rem) clamp(2rem,6vw,6rem);gap:clamp(1.1rem,2vw,1.6rem); }
  .split__rule { width:2.5rem;height:1.5px;background-color:var(--split-accent);margin-bottom:0.25rem;flex-shrink:0; }
  .split__eyebrow { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(0.7rem,1vw,0.8rem);font-weight:400;letter-spacing:0.25em;text-transform:uppercase;color:var(--split-accent);margin:0; }
  .split__heading { font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:300;line-height:1.1;letter-spacing:-0.015em;color:var(--split-text);margin:0; }
  .split__heading em { font-style:italic;font-weight:300; }
  .split__text { font-size:clamp(0.9rem,1.3vw,1rem);font-weight:300;line-height:1.8;color:var(--split-text-muted);max-width:46ch;margin:0; }
  .split__text p { margin:0 0 0.75em; }
  .split__text p:last-child { margin-bottom:0; }
  .split__features { list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.65rem;border-top:1px solid var(--split-rule-color);padding-top:clamp(1rem,2vw,1.5rem);margin-top:0.25rem; }
  .split__feature-item { display:flex;align-items:center;gap:0.75rem;font-size:clamp(0.8rem,1.1vw,0.875rem);font-weight:400;letter-spacing:0.04em;color:var(--split-text-muted); }
  .split__feature-icon { flex-shrink:0;color:var(--split-accent); }
  .split__cta { margin-top:0.5rem; }
  .split__btn { display:inline-flex;align-items:center;gap:1.2rem;color:var(--split-text);text-decoration:none;font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(0.85rem,1.2vw,0.95rem);font-weight:500;letter-spacing:0.15em;text-transform:uppercase;padding-bottom:0.3em;border-bottom:1px solid var(--split-rule-color);transition:gap 0.35s cubic-bezier(0.22,1,0.36,1),border-color 0.3s ease,color 0.3s ease; }
  .split__btn:hover,.split__btn:focus-visible { gap:2rem;border-color:var(--split-accent);color:var(--split-accent);outline:none; }
  .split__btn-arrow { flex-shrink:0;transition:transform 0.35s cubic-bezier(0.22,1,0.36,1); }
  .split__btn:hover .split__btn-arrow { transform:translateX(6px); }
  @media (prefers-reduced-motion:no-preference) {
    .split__reveal { opacity:0;transform:translateY(28px);transition:opacity 0.75s cubic-bezier(0.22,1,0.36,1) var(--reveal-delay,0s),transform 0.75s cubic-bezier(0.22,1,0.36,1) var(--reveal-delay,0s); }
    .split__reveal--media { opacity:0;transform:translateX({% if img_left %}-3%{% else %}3%{% endif %});transition:opacity 1s cubic-bezier(0.22,1,0.36,1) 0s,transform 1s cubic-bezier(0.22,1,0.36,1) 0s; }
    .split__reveal.is-visible,.split__reveal--media.is-visible { opacity:1;transform:translate(0,0); }
  }
  @media screen and (max-width:899px) {
    .split__grid { grid-template-columns:1fr;grid-template-rows:auto auto;min-height:unset; }
    .split--img-right .split__media,.split--img-left .split__media { order:unset; }
    .split--img-right .split__body,.split--img-left .split__body { order:unset; }
    .split__media { order:1; }
    .split__body { order:2; }
    .split__image-wrap { position:relative;height:55vw;min-height:260px; }
    .split__text { max-width:100%; }
    .split__body { padding:clamp(2.5rem,8vw,4rem) clamp(1.25rem,5vw,2.5rem); }
    .split__reveal--media { transform:translateY(20px) !important; }
  }
</style>
<script>
(function(){
  var s=document.getElementById('split-{{ section.id }}');
  if(!s)return;
  var t=s.querySelectorAll('.split__reveal,.split__reveal--media');
  if(!t.length)return;
  if(!('IntersectionObserver' in window)){t.forEach(function(e){e.classList.add('is-visible');});return;}
  var io=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:0.12});
  t.forEach(function(e){io.observe(e);});
})();
</script>

{% schema %}
{
  "name": "Split — Image & Text",
  "tag": "section",
  "class": "section-split",
  "settings": [
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image side", "options": [{ "value": "left", "label": "Left" },{ "value": "right", "label": "Right" }], "default": "left" },
    { "type": "range", "id": "image_height", "label": "Minimum section height", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 580 },
    { "type": "text", "id": "image_caption", "label": "Image caption" },
    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_rule", "label": "Show decorative rule", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Crafted for <em>generations.</em></p>" },
    { "type": "richtext", "id": "text", "label": "Body text", "default": "<p>Every hearth we create is built by hand, using materials chosen to age beautifully.</p>" },
    { "type": "header", "content": "Feature points" },
    { "type": "text", "id": "feature_1", "label": "Feature 1", "default": "Solid cast iron construction" },
    { "type": "text", "id": "feature_2", "label": "Feature 2", "default": "10-year structural warranty" },
    { "type": "text", "id": "feature_3", "label": "Feature 3", "default": "Free nationwide installation" },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Our story" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Style" },
    { "type": "select", "id": "color_scheme", "label": "Colour scheme", "options": [{ "value": "light", "label": "Light" },{ "value": "dark", "label": "Dark" }], "default": "light" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [
    {
      "name": "Split — Image & Text",
      "settings": { "eyebrow": "Our craft", "heading": "<p>Crafted for <em>generations.</em></p>", "text": "<p>Every hearth we create is built by hand.</p>", "feature_1": "Solid cast iron construction", "feature_2": "10-year structural warranty", "feature_3": "Free nationwide installation", "button_label": "Our story", "image_position": "left", "color_scheme": "light", "show_rule": true, "image_height": 580, "padding_top": 80, "padding_bottom": 80 }
    }
  ]
}
{% endschema %}
